execute "ALTER TABLE releases DROP INDEX index_releases_on_app_id_and_version_code, ADD INDEX index_releases_on_app_id_and_version_code (app_id, version_code)" do |connection|
  rows = connection.select_all("SHOW INDEX FROM releases WHERE Key_name = 'index_releases_on_app_id_and_version_code'").to_a
  rows.any? { |row| row.fetch("Non_unique").to_i == 0 }
end

execute "ALTER TABLE releases ADD INDEX index_releases_on_app_id_and_version_code (app_id, version_code)" do |connection|
  connection.select_all("SHOW INDEX FROM releases WHERE Key_name = 'index_releases_on_app_id_and_version_code'").to_a.empty?
end

