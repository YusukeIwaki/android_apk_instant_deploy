<div class="mb-3"><a href="/devices" class="text-decoration-none">&larr; Back to devices</a></div>

<div class="d-flex align-items-center justify-content-between mb-3">
  <div>
    <h1 class="h4 mb-0"><code><%= h(device.identifier) %></code></h1>
    <p class="text-muted mb-0"><%= h(profile&.display_name) %></p>
  </div>
  <div>
    <a href="/policies/<%= h(device.identifier) %>/edit" class="btn btn-sm btn-primary">Edit policy</a>
    <form method="post" action="/devices/<%= h(device.identifier) %>/delete" class="d-inline" onsubmit="return confirm('Delete this device?');">
      <button class="btn btn-sm btn-outline-danger" type="submit">Delete device</button>
    </form>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-md-6">
    <div class="table-card h-100">
      <h2 class="h6 text-muted">Device</h2>
      <dl class="row mb-0">
        <dt class="col-sm-4">Registered at</dt>
        <dd class="col-sm-8"><%= h(timestamp(device.registered_at)) %></dd>
        <dt class="col-sm-4">FCM registered</dt>
        <dd class="col-sm-8"><%= h(timestamp(fcm_token&.last_registered_at)) %></dd>
      </dl>
    </div>
  </div>
  <div class="col-md-6">
    <div class="table-card h-100">
      <h2 class="h6 text-muted">Current policy</h2>
      <% if revision %>
        <dl class="row mb-2">
          <dt class="col-sm-4">Revision</dt>
          <dd class="col-sm-8">#<%= revision.id %></dd>
          <dt class="col-sm-4">Updated</dt>
          <dd class="col-sm-8"><%= h(timestamp(policy.updated_at)) %></dd>
        </dl>
        <% if entries.empty? %>
          <p class="text-muted small mb-0">No app entries.</p>
        <% else %>
          <table class="table table-sm mb-0">
            <thead><tr><th>Package</th><th>Mode</th></tr></thead>
            <tbody>
              <% entries.each do |entry| %>
                <tr>
                  <td><code><%= h(entry.app.package_name) %></code></td>
                  <td><span class="badge bg-<%= entry.install_mode == "FORCE_INSTALLED" ? "danger" : "info" %>"><%= h(entry.install_mode) %></span></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% end %>
      <% else %>
        <p class="text-muted small mb-0">No policy applied yet.</p>
      <% end %>
    </div>
  </div>
</div>

<div class="table-card">
  <h2 class="h6 text-muted mb-3">Recent sync reports</h2>
  <% if reports.empty? %>
    <p class="text-muted small mb-0">No sync reports received yet.</p>
  <% else %>
    <div class="table-responsive">
      <table class="table table-sm align-middle mb-0">
        <thead>
          <tr>
            <th>Reported at</th>
            <th>Revision</th>
            <th>Fetched</th>
            <th>Applied</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% reports.each do |report| %>
            <tr>
              <td><%= h(timestamp(report.reported_at)) %></td>
              <td>#<%= report.device_policy_revision_id %></td>
              <td><%= h(timestamp(report.fetched_policy_updated_at)) %></td>
              <td><%= h(timestamp(report.applied_policy_updated_at)) %></td>
              <td><%= Array(report.actions).length %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
