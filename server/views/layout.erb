<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= h(@title ? "#{@title} · APK Instant Deploy" : "APK Instant Deploy") %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
  <style>
    body { background-color: #f6f7fb; }
    .nav-brand-mark { font-weight: 600; letter-spacing: 0.02em; }
    .stat-card { border: none; border-radius: 12px; }
    .stat-card .display-6 { font-weight: 600; }
    .table-card { background: #fff; border-radius: 12px; padding: 1.25rem; box-shadow: 0 1px 2px rgba(0,0,0,0.04); }
    code, pre { word-break: break-all; }
  </style>
</head>
<body>
  <% if session[:authenticated] %>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-3">
      <div class="container-fluid">
        <a class="navbar-brand nav-brand-mark" href="/">APK Instant Deploy</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="mainNav">
          <ul class="navbar-nav me-auto">
            <li class="nav-item"><a class="nav-link<%= " active" if request.path_info == "/" %>" href="/">Dashboard</a></li>
            <li class="nav-item"><a class="nav-link<%= " active" if request.path_info.start_with?("/devices") %>" href="/devices">Devices</a></li>
            <li class="nav-item"><a class="nav-link<%= " active" if request.path_info.start_with?("/apps") %>" href="/apps">Apps</a></li>
            <li class="nav-item"><a class="nav-link<%= " active" if request.path_info.start_with?("/policies") %>" href="/policies">Policies</a></li>
          </ul>
          <form method="post" action="/logout">
            <button class="btn btn-outline-light btn-sm" type="submit">Sign out</button>
          </form>
        </div>
      </div>
    </nav>
  <% end %>
  <main class="container pb-5">
    <% if @flash %>
      <div class="alert alert-<%= h(@flash[:type]) %>" role="alert"><%= h(@flash[:message]) %></div>
    <% end %>
    <%= yield %>
  </main>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
