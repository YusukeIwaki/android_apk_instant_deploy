<div class="mb-3"><a href="/policies" class="text-decoration-none">&larr; Back to policies</a></div>

<h1 class="h4 mb-1">Edit policy</h1>
<p class="text-muted">Device: <code><%= h(device.identifier) %></code> · <%= h(device.device_profile&.display_name) %></p>

<% if apps.empty? %>
  <div class="alert alert-warning">No apps are registered. <a href="/apps/new" class="alert-link">Upload an APK</a> before assigning a policy.</div>
<% else %>
  <form method="post" action="/policies/<%= h(device.identifier) %>">
    <div class="table-card mb-3">
      <table class="table align-middle mb-0">
        <thead>
          <tr>
            <th style="width: 4rem;">Include</th>
            <th>Package</th>
            <th>Display name</th>
            <th style="width: 18rem;">Install mode</th>
          </tr>
        </thead>
        <tbody>
          <% apps.each do |app|
               selected = current_entries.key?(app.id)
               mode = current_entries[app.id] || "AVAILABLE"
          %>
            <tr>
              <td>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="include[]" value="<%= app.id %>" id="include_<%= app.id %>"<%= selected ? " checked" : "" %>>
                </div>
              </td>
              <td><code><%= h(app.package_name) %></code></td>
              <td><%= h(app.app_profile&.display_name) %></td>
              <td>
                <div class="btn-group btn-group-sm w-100" role="group">
                  <input type="radio" class="btn-check" name="install_mode[<%= app.id %>]" id="mode_<%= app.id %>_force" value="FORCE_INSTALLED"<%= mode == "FORCE_INSTALLED" ? " checked" : "" %>>
                  <label class="btn btn-outline-danger" for="mode_<%= app.id %>_force">FORCE_INSTALLED</label>

                  <input type="radio" class="btn-check" name="install_mode[<%= app.id %>]" id="mode_<%= app.id %>_avail" value="AVAILABLE"<%= mode == "AVAILABLE" ? " checked" : "" %>>
                  <label class="btn btn-outline-info" for="mode_<%= app.id %>_avail">AVAILABLE</label>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="d-flex justify-content-between">
      <a href="/policies" class="btn btn-outline-secondary">Cancel</a>
      <button class="btn btn-primary" type="submit">Publish new revision</button>
    </div>
  </form>
<% end %>
