---
import DiagramFrame from "../../../components/DiagramFrame.astro";
import Mermaid from "../../../components/Mermaid.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";

const createTokenCurl = `curl -X POST https://distribution.example.test/admin/device_registration_tokens \\
  -H "Authorization: Bearer $ADMIN_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    "expires_in_minutes": 30
  }'`;

const createTokenResponse = `HTTP/1.1 201 Created
{
  "device_registration_token": {
    "identifier": "drt_01HX9A2W...",
    "registration_secret": "drs_4Gk...",
    "issued_at": "2026-05-19T09:41:00+09:00",
    "expires_at": "2026-05-19T10:11:00+09:00",
    "deep_link": "apkdist://register-device?identifier=drt_01HX9A2W...&secret=drs_4Gk...&server_base_url=https%3A%2F%2Fdistribution.example.test"
  }
}`;

const deepLinkExample = `apkdist://register-device?identifier=drt_01HX9A2W...&secret=drs_4Gk...&server_base_url=https%3A%2F%2Fdistribution.example.test`;

const createDeviceCurl = `curl -X POST https://distribution.example.test/api/devices \\
  -H "Content-Type: application/json" \\
  -d '{
    "identifier": "drt_01HX9A2W...",
    "registration_secret": "drs_4Gk...",
    "display_name": "Pixel 8 QA-01",
    "fcm_push_token": "fcm:APA91b..."
  }'`;

const createDeviceResponse = `HTTP/1.1 201 Created
{
  "device": {
    "identifier": "drt_01HX9A2W...",
    "device_auth_token": "dat_6m2...",
    "profile": {
      "display_name": "Pixel 8 QA-01"
    },
    "registered_at": "2026-05-19T09:41:32+09:00"
  }
}

# device_auth_token はこのレスポンスでだけ平文を返す。
# 端末は private storage に保存し、以後のAPI呼び出しで Bearer として送る。`;

const alreadyRegisteredResponse = `HTTP/1.1 403 Forbidden
{
  "error": {
    "code": "DEVICE_ALREADY_REGISTERED",
    "message": "A device already exists for this identifier."
  }
}

# 同じ device_identifiers (identifier 文字列) を握っている devices 行が既にある場合に返す。
# このとき device_profiles / fcm_push_tokens / device_credentials は触らない。`;

const expiredOrSecretMismatchResponse = `HTTP/1.1 404 Not Found
{
  "error": {
    "code": "REGISTRATION_TOKEN_NOT_FOUND",
    "message": "Registration link is expired, already used, or the secret is incorrect."
  }
}

# 期限切れ / secret不一致 / 既に使用済み はすべて同じレスポンスにまとめる。
# 失敗理由を細かく返すと、リンク総当たりの手掛かりになるため。`;

const sequence = `sequenceDiagram
  autonumber
  actor Admin as 管理者
  actor User as 端末利用者
  participant Api as APIサーバー
  participant Launcher as QR reader / OS
  participant App as コンパニオンアプリ
  participant Push as FCM
  participant Registry as Device registry

  Admin->>Api: デバイス登録リンクを作成
  Api->>Registry: DeviceRegistrationTokenを保存
  Api-->>Admin: custom scheme URL / QRコードを表示
  User->>Launcher: 端末でQRまたはリンクを開く
  Launcher->>App: custom schemeでアプリ起動
  App->>Push: FCM tokenを取得
  Push-->>App: FCM token
  User->>App: 表示名を入力して登録
  App->>Api: device create(identifier, secret, display_name, FCM token)
  Api->>Registry: token検証、Device/profile/credential/fcm token作成、token削除
  Api-->>App: identifier, device_auth_token, profileを返す
  App-->>User: 登録完了を表示
  User->>Launcher: 同じQRまたはリンクを再度開く
  Launcher->>App: custom schemeでアプリ起動
  App->>Api: device create(same identifier, secret)
  Api->>Registry: token行なし、同 device_identifier_id の devices 行あり
  Api-->>App: 403 DEVICE_ALREADY_REGISTERED
  App-->>User: 登録済みリンクとして表示`;

const state = `stateDiagram-v2
  [*] --> TokenIssued
  TokenIssued --> AppLaunched: custom schemeでアプリ起動
  AppLaunched --> WaitingPushToken: FCM token取得待ち
  WaitingPushToken --> WaitingDisplayName: FCM token取得完了
  WaitingDisplayName --> CreatingDevice: 表示名入力後に登録
  CreatingDevice --> DeviceCreated: devices新規作成
  CreatingDevice --> Rejected: 期限切れ / 登録済みリンク / secret不一致
  DeviceCreated --> TokenRemoved: DeviceRegistrationToken削除
  TokenRemoved --> Completed: 登録完了を表示
  Completed --> ReuseAttempted: 同じQRまたはリンクを再度開く
  ReuseAttempted --> AlreadyRegistered: token行なし + devicesあり
  AlreadyRegistered --> Completed: 既存登録は維持
  Completed --> [*]
  Rejected --> [*]`;

const identityFlow = `flowchart LR
  subgraph Token["DeviceRegistrationToken"]
    TokenIdentifier["identifier<br/>サーバーが発行 (device_identifiers に新規行を作る)"]
    RegistrationSecret["registration secret<br/>URL/QRに含める一回限りの秘密"]
  end

  subgraph DeviceSide["端末"]
    Browser["QR reader / OS<br/>custom schemeを開く"]
    App["コンパニオンアプリ<br/>identifierを受け取る"]
    PushToken["FCM push token<br/>FCMから取得"]
    DisplayName["表示名<br/>ユーザーが必須入力"]
    Credential["identifier + device_auth_token<br/>登録成功後に保存"]
  end

  subgraph Server["APIサーバー"]
    IdentifierRecord["device_identifiers<br/>id / identifier (UNIQUE)<br/>= identifier 文字列を一元管理"]
    TokenRecord["device_registration_tokens<br/>id / device_identifier_id (UNIQUE FK) /<br/>secret_hash / issued_at / expires_at"]
    DeviceRecord["devices<br/>id / device_identifier_id (UNIQUE FK) /<br/>registered_at"]
    ProfileRecord["device_profiles<br/>device_id / display_name"]
    CredentialRecord["device_credentials<br/>device_id / token_hmac"]
    PushRecord["fcm_push_tokens<br/>device_id / token_hash / encrypted_token"]
  end

  IdentifierRecord --> TokenRecord
  IdentifierRecord -. "登録成功で device 側へ" .-> DeviceRecord
  TokenIdentifier --> Browser --> App
  RegistrationSecret --> Browser
  App -->|device create| DeviceRecord
  TokenRecord -->|secret 検証後に token 行のみ削除| DeviceRecord
  DisplayName -->|必須入力| ProfileRecord
  PushToken -->|同時送信| PushRecord
  DeviceRecord -->|issue| Credential
  Credential -->|HMAC化して保管| CredentialRecord
  ProfileRecord --> DeviceRecord
  PushRecord --> DeviceRecord
  CredentialRecord --> DeviceRecord`;
---

<BaseLayout
  title="デバイスの登録"
  description="デバイス登録リンクまたはQRコードからコンパニオンアプリを起動し、FCM tokenと表示名をもとにdevicesを新規作成します。"
  currentPath="/use-cases/device-registration/"
>
  <p class="lede">
    デバイス登録は、事前にDeviceを作っておく処理ではありません。
    サーバーが発行したDeviceRegistrationTokenを端末アプリへ渡し、アプリがFCM tokenを取得してから、表示名とともにdevicesを新規作成します。
    受け渡し経路は2つあり、AMAPI管理外端末は custom scheme URL / QR コード、AMAPI管理端末は <a href="/android-app-prereq/#managed-configuration">AMAPI policy の <code>managedConfiguration</code></a> を使います。
    どちらも同じ <code>POST /api/devices</code> に集約され、Android Management API のmanaged-device enrollmentとは別物です。
  </p>
  <p class="lede">
    identifier (端末を外部から指す文字列) は <strong>専用テーブル <code>device_identifiers</code> に UNIQUE 制約付きで一元管理</strong> します。<code>devices</code> と <code>device_registration_tokens</code> は <code>device_identifier_id</code> で同じ行を参照する形にし、<em>同一 identifier が同時に「未使用 token」と「登録済み device」になる可能性を DB レベルで排除</em> します。
  </p>

  <section aria-labelledby="actors">
    <p class="section-kicker">Actors and responsibilities</p>
    <h2 id="actors">登場人物と責務</h2>
    <div class="table-wrap">
      <table class="usa-table">
        <thead>
          <tr>
            <th scope="col">登場人物</th>
            <th scope="col">きっかけ</th>
            <th scope="col">責務</th>
            <th scope="col">参照する識別子</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <th scope="row">管理者</th>
            <td>新しい端末を登録枠に追加したい</td>
            <td>管理画面でデバイス登録リンクを発行し、端末利用者に渡す。</td>
            <td>DeviceRegistrationToken.identifier (発行時にサーバーが付与)</td>
          </tr>
          <tr>
            <th scope="row">端末利用者</th>
            <td>渡されたリンクまたはQRコード</td>
            <td>コンパニオンアプリを開き、表示名を入力して登録ボタンを押す。</td>
            <td>登録リンク (identifier + secret)</td>
          </tr>
          <tr>
            <th scope="row">コンパニオンアプリ</th>
            <td>custom scheme deep linkでの起動</td>
            <td>FCM tokenを取得してから登録ボタンを有効化し、APIへ登録要求を送り、返ってきた device_auth_token を端末内に保存する。</td>
            <td>identifier, registration secret, FCM token, device_auth_token</td>
          </tr>
          <tr>
            <th scope="row">APIサーバー</th>
            <td>POST /api/devices</td>
            <td>tokenを検証し、devices / device_profiles / device_credentials / fcm_push_tokens を1トランザクションで作成し、device_registration_tokens 行を削除する。</td>
            <td>device_identifier_id (= devices と device_registration_tokens が共通参照する device_identifiers 行)</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section aria-labelledby="registration-flow">
    <p class="section-kicker">Flow with data</p>
    <h2 id="registration-flow">処理フロー</h2>

    <article class="flow-step" aria-labelledby="step-1">
      <div class="flow-step__header">
        <span class="flow-step__number">1</span>
        <div>
          <h3 id="step-1">管理者がデバイス登録リンクを発行する</h3>
          <p>管理画面または管理APIで登録リンクを作成します。リンクには <code>identifier</code> と一回限りの <code>secret</code> が含まれ、QRコードや共有リンクとして渡せます。この時点ではまだdevicesは作られません。</p>
        </div>
      </div>
      <div class="flow-step__grid">
        <div>
          <DiagramFrame src="/mocks/device-registration/step-1-admin-token.html" title="管理画面: デバイス登録リンク作成" />
        </div>
        <div class="flow-step__details">
          <h4>API呼び出し</h4>
          <pre class="curl-block"><code>{createTokenCurl}</code></pre>
          <h4>応答</h4>
          <pre class="curl-block"><code>{createTokenResponse}</code></pre>
          <h4>作成されるDBデータ</h4>
          <dl class="db-list">
            <div>
              <dt>device_identifiers</dt>
              <dd>新しい identifier 文字列を生成し、<code>device_identifiers</code> 行を1つ作る。<code>identifier</code> 列に UNIQUE 制約。以後、登録 token も登録済み device もこの行を <code>device_identifier_id</code> で参照する。</dd>
            </div>
            <div>
              <dt>device_registration_tokens</dt>
              <dd><code>device_identifier_id</code> (UNIQUE FK)、secret_hash、issued_at、expires_at を保存する。状態カラムは持たない。secret は hash だけ保存し、平文は応答にのみ含める。行は登録成功時に削除される (= 識別子の所有権が device 側へ移る)。</dd>
            </div>
            <div>
              <dt>registration_secret の保護</dt>
              <dd>secret は128bit以上の乱数で生成し、サーバーには Argon2id または bcrypt の hash だけ保存する。照合は identifier で候補行を引いた後、定数時間比較できるライブラリに委ねる。同一 identifier と送信元IPの短時間連続失敗は rate limit する。</dd>
            </div>
            <div>
              <dt>Admin API token</dt>
              <dd>DeviceRegistrationToken 発行は admin bearer token で受け付ける。token は平文をDBに保存せず HMAC で保管する。admin / CI / readonly のロール分離は MVP では行わない (将来必要になったら別ユースケースで追加)。</dd>
            </div>
            <div>
              <dt>devices</dt>
              <dd>まだ作成しない。<code>device_identifiers.identifier</code> は未使用の登録枠に載った予約済み識別子として扱う (この時点では <code>devices</code> 行は無く、<code>device_registration_tokens</code> 行だけが <code>device_identifier_id</code> を握っている)。</dd>
            </div>
          </dl>
        </div>
      </div>
    </article>

    <article class="flow-step" aria-labelledby="step-2">
      <div class="flow-step__header">
        <span class="flow-step__number">2</span>
        <div>
          <h3 id="step-2">端末でcustom schemeリンクまたはQRコードを開く</h3>
          <p>QRコードやリンクに含まれるcustom scheme URLから、OSがコンパニオンアプリを直接起動します。ブラウザ上の中継ページは挟みません。FCM tokenの取得はアプリ起動後に行う必要があるため、ブラウザベースの登録ページにはしません。</p>
        </div>
      </div>
      <div class="flow-step__grid">
        <div>
          <DiagramFrame src="/mocks/device-registration/step-2-deep-link.html" title="スマートフォン: QR読み取りからアプリ起動" />
        </div>
        <div class="flow-step__details">
          <h4>端末が受け取るURL</h4>
          <pre class="curl-block"><code>{deepLinkExample}</code></pre>
          <h4>この時点での処理</h4>
          <dl class="db-list">
            <div>
              <dt>サーバーAPI</dt>
              <dd>呼ばれない。アプリが起動しただけでは登録扱いにしない。</dd>
            </div>
            <div>
              <dt>device_registration_tokens</dt>
              <dd>触らない。識別子の有効性検証は POST /api/devices のときに行う。</dd>
            </div>
            <div>
              <dt>devices</dt>
              <dd>触らない。FCM token取得と表示名入力が終わるまで登録完了ではない。</dd>
            </div>
          </dl>
          <h4>端末側の前提</h4>
          <p>コンパニオンアプリ未インストールの場合、OSはアプリ選択画面を出すかリンクを開けない。事前にアプリのインストール経路 (Managed Play、社内ストア、APKサイドロード) を確保しておくことが前提です。</p>
        </div>
      </div>
    </article>

    <article class="flow-step" aria-labelledby="step-3">
      <div class="flow-step__header">
        <span class="flow-step__number">3</span>
        <div>
          <h3 id="step-3">アプリがFCM tokenと表示名を送ってdevicesを作成する</h3>
          <p>コンパニオンアプリはFCM tokenを取得できるまで登録ボタンを無効にします。表示名は必須入力で、登録後も変更可能なprofile情報として扱います。サーバーはtoken検証 → devices/profile/credential/fcm_push_token作成 → device_registration_tokens削除を1トランザクションで行います。</p>
        </div>
      </div>
      <div class="flow-step__grid">
        <div>
          <DiagramFrame src="/mocks/device-registration/step-3-companion-app.html" title="コンパニオンアプリ: 登録確認画面" />
        </div>
        <div class="flow-step__details">
          <h4>API呼び出し</h4>
          <pre class="curl-block"><code>{createDeviceCurl}</code></pre>
          <h4>成功時の応答</h4>
          <pre class="curl-block"><code>{createDeviceResponse}</code></pre>
          <h4>作成・更新されるDBデータ (1トランザクション)</h4>
          <dl class="db-list">
            <div>
              <dt>devices</dt>
              <dd><code>device_identifier_id</code> (UNIQUE FK) を、tokenと同じ <code>device_identifiers</code> 行に設定して新規作成。<code>registered_at</code> を保存する。identifier 文字列は <code>device_identifiers</code> 側を経由して取得し、<code>devices</code> 行には直接持たない。表示名や enabled/active といった可変状態もここに持たない。</dd>
            </div>
            <div>
              <dt>device_profiles</dt>
              <dd>device_id、display_name、updated_at を保存する。表示名は後から変更可能で、identifier を重複保持しない。OS / 機種 / SDK バージョン等の自動収集はしない。</dd>
            </div>
            <div>
              <dt>device_credentials</dt>
              <dd>device_id、device_auth_token の HMAC 値、issued_at を保存する。平文 token は応答に1度だけ含め、サーバーは HMAC 値のみ保持する。HMAC のキーはアプリ側のシークレット (環境変数等) で管理。MVP では再発行・強制失効APIを持たない (再登録で <code>device_registration_tokens</code> を再発行する経路に集約)。</dd>
            </div>
            <div>
              <dt>fcm_push_tokens</dt>
              <dd>device_id、token_hash、encrypted_token、last_registered_at を upsert する。同じ identifier の最新tokenとして扱い、過去値に対する別処理は行わない。encrypted_token は KMS などの envelope encryption で暗号化し、復号鍵はアプリDBとは別のsecret管理に置く。</dd>
            </div>
            <div>
              <dt>device_registration_tokens</dt>
              <dd>登録成功後にこの行を削除する。「使用済み」フラグは持たず、行の不在をもって登録完了とみなす。</dd>
            </div>
          </dl>
        </div>
      </div>
    </article>

    <article class="flow-step" aria-labelledby="step-4">
      <div class="flow-step__header">
        <span class="flow-step__number">4</span>
        <div>
          <h3 id="step-4">登録完了を表示し、登録済みリンクの再利用を拒否する</h3>
          <p>登録成功時はアプリに完了画面を表示します。同じDeviceRegistrationTokenで再アクセスされた場合は、同じ <code>device_identifier_id</code> を持つ <code>devices</code> 行が存在することをもって登録済みと判断し、devicesやprofileを新規作成・更新しません。</p>
        </div>
      </div>
      <div class="flow-step__grid">
        <div>
          <DiagramFrame src="/mocks/device-registration/step-4-registered.html" title="コンパニオンアプリ: 登録完了と登録済みリンク" />
        </div>
        <div class="flow-step__details">
          <h4>登録済みリンクで再登録された場合の応答</h4>
          <pre class="curl-block"><code>{alreadyRegisteredResponse}</code></pre>
          <h4>期限切れ / secret不一致 の応答</h4>
          <pre class="curl-block"><code>{expiredOrSecretMismatchResponse}</code></pre>
          <h4>DBデータの扱い</h4>
          <dl class="db-list">
            <div>
              <dt>devices</dt>
              <dd>既存の identifier をそのまま維持し、新しい行は作成しない。</dd>
            </div>
            <div>
              <dt>device_registration_tokens</dt>
              <dd>登録完了時に削除済みなので、同じ identifier では検証対象の行が見つからない。期限切れの行も背景処理で削除してよい。</dd>
            </div>
            <div>
              <dt>device_profiles / fcm_push_tokens / device_credentials</dt>
              <dd>登録済みリンクによる再登録では更新しない。新しい端末を登録する場合は管理者が DeviceRegistrationToken を再発行する。</dd>
            </div>
          </dl>
        </div>
      </div>
    </article>
  </section>

  <section aria-labelledby="identity">
    <p class="section-kicker">Identity ownership</p>
    <h2 id="identity">誰がどのidentifierを持つか</h2>
    <Mermaid chart={identityFlow} title="DeviceRegistrationToken、端末、devices、device_profiles、fcm_push_tokensの関係" />
    <div class="table-wrap">
      <table class="usa-table">
        <thead>
          <tr>
            <th scope="col">identifier</th>
            <th scope="col">生成者</th>
            <th scope="col">保持場所</th>
            <th scope="col">用途</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <th scope="row">device_identifiers.identifier</th>
            <td>APIサーバー</td>
            <td>専用テーブル <code>device_identifiers</code> に UNIQUE 制約付きで1行 + URL/QR と端末内 private storage。<code>devices</code> と <code>device_registration_tokens</code> は <code>device_identifier_id</code> でこの行を参照する。</td>
            <td>identifier 文字列を1箇所で持つことで、「未使用 token」と「登録済み device」が同じ identifier を同時に握ることを DB 制約で禁止する。新規発行は常に新しい行 (= 新しい identifier) として作る。</td>
          </tr>
          <tr>
            <th scope="row">registration secret</th>
            <td>APIサーバー</td>
            <td>URL/QR には平文、サーバー側は hash のみ (<code>device_registration_tokens.secret_hash</code>)。</td>
            <td>リンクを知っているだけの第三者登録を防ぐ一回限りの秘密。期限切れ、secret不一致、または同じ <code>device_identifier_id</code> を持つ <code>devices</code> 行がある場合は拒否する。</td>
          </tr>
          <tr>
            <th scope="row">devices.device_identifier_id (外部から見ると identifier)</th>
            <td>APIサーバー</td>
            <td>devices と端末内 private storage。</td>
            <td>登録済み端末を外部から特定する安定した参照。API URL では <code>device_identifiers.identifier</code> の文字列をそのまま使う (DB上の参照は <code>devices.id</code>)。</td>
          </tr>
          <tr>
            <th scope="row">device_auth_token</th>
            <td>APIサーバー</td>
            <td>端末内 private storage。サーバー側は <code>device_credentials.token_hmac</code> として HMAC 値を保持する。</td>
            <td>登録済み端末からの後続API呼び出しで、identifier に対する本人性を確認する。MVPでは強制失効・再発行APIを持たず、不要になった端末は <code>DELETE /admin/devices/:identifier</code> で device 行ごと消す。再登録は新しい DeviceRegistrationToken の発行から行う。</td>
          </tr>
          <tr>
            <th scope="row">FCM push token</th>
            <td>FCM</td>
            <td>端末側は最新値、サーバー側は fcm_push_tokens に暗号化値と hash。</td>
            <td>Policy更新を端末へ通知する宛先。ローテーション時は identifier で upsert する。</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

