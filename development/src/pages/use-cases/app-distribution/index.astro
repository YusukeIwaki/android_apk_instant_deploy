---
import DiagramFrame from "../../../components/DiagramFrame.astro";
import Mermaid from "../../../components/Mermaid.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";

const touchPoliciesCurl = `curl -X POST https://distribution.example.test/admin/apps/com.example.appa/touch_policies \\
  -H "Authorization: Bearer $ADMIN_TOKEN"`;

const touchPoliciesCli = `ANDROID_APK_INSTANT_DEPLOY_SERVER=https://distribution.example.test \\
ANDROID_APK_INSTANT_DEPLOY_ACCESS_TOKEN=$ADMIN_TOKEN \\
android_apk_instant_deploy touch_policies --app com.example.appa`;

const touchPoliciesResponse = `HTTP/1.1 200 OK
{
  "device_policies": [
    {
      "identifier": "drt_01HX9A2W...",
      "display_name": "QA handset 01",
      "current_revision": { "id": 902 },
      "updated_at": "2026-05-23T10:12:00+09:00"
    }
  ]
}

# 指定 package_name の app を含む current revision だけを対象に、
# entries を変えずに新しい revision を作って current にする。
# 新しい app を policy に追加したり、install_mode を変更したりはしない。`;

const policyEditorBehavior = `管理画面のポリシー編集画面
- 登録済みアプリ一覧を表示する
- Include と install_mode を選んで Publish new revision する
- entry は app と install_mode だけを保存し、release / version は保存しない
- Policy 更新後、FCM data message を送る
- どの release を配るかは端末の GET /api/devices/me/policy 時にサーバーが解決する`;

const policyEditorRevision = `新しい revision の作成結果
device_policy:
  identifier: drt_01HX9A2W...
  current_revision:
    id: 901
  updated_at: 2026-05-23T10:12:00+09:00
entries:
  - app:
      package_name: com.example.appa
    install_mode: FORCE_INSTALLED
  - app:
      package_name: com.example.appd
    install_mode: AVAILABLE`;

const fcmDataMessage = `{
  "message": {
    "token": "fcm:APA91b...",
    "data": {
      "type": "POLICY_UPDATED",
      "identifier": "drt_01HX9A2W...",
      "device_policy_updated_at": "2026-05-23T10:12:00+09:00"
    }
  }
}

# notification payload は含めない。
# 端末はこの受信で pending_policy_fetch フラグを立て、次のオンライン時または起動時に Policy 取得を試みる。
# FCM を取りこぼした場合でも、利用者がアプリを明示起動して手動更新すれば復旧できる設計にする。`;

const fetchPolicyCurl = `curl -X GET https://distribution.example.test/api/devices/me/policy \\
  -H "Authorization: Bearer $DEVICE_AUTH_TOKEN"`;

const fetchPolicyResponse = `HTTP/1.1 200 OK
{
  "device_policy_revision": { "id": 901 },
  "updated_at": "2026-05-23T10:12:00+09:00",
  "server_time": "2026-05-23T10:12:04+09:00",
  "entries": [
    {
      "app": { "id": 12, "package_name": "com.example.appa", "display_name": "勤怠アプリ" },
      "install_mode": "FORCE_INSTALLED",
      "install": { "release": { "id": 301 }, "version_code": 42, "version_name": "2.4.0-qa", "artifact_sha256": "58f7d4..." }
    },
    {
      "app": { "id": 13, "package_name": "com.example.appb", "display_name": "棚卸アプリ" },
      "install_mode": "FORCE_INSTALLED",
      "install": { "release": { "id": 410 }, "version_code": 5, "version_name": "1.2.0", "artifact_sha256": "9a81c0..." }
    },
    {
      "app": { "id": 14, "package_name": "com.example.appc", "display_name": "配送アプリ" },
      "install_mode": "FORCE_INSTALLED",
      "install": { "release": { "id": 520 }, "version_code": 9, "version_name": "0.9.3", "artifact_sha256": "35cd02..." }
    },
    {
      "app": { "id": 15, "package_name": "com.example.appd", "display_name": "社内ポータル" },
      "install_mode": "AVAILABLE",
      "install": { "release": { "id": 612 }, "version_code": 3, "version_name": "0.3.1", "artifact_sha256": "66ad22..." }
    }
  ]
}

# 端末向け応答には削除済み app の entry は存在し得ない。
# install は必ず非null (release が無い app は entry を持てないため)。`;

const downloadUrlCurl = `curl -X GET https://distribution.example.test/api/releases/301/artifact_url \\
  -H "Authorization: Bearer $DEVICE_AUTH_TOKEN"

# Policy fetch で受け取った install.release.id をそのまま使う。
# FORCE_INSTALLED で未インストール、要求 version_code が新しい、または同じ version_code で artifact_sha256 が異なる場合だけ取得する。
# AVAILABLE の未インストールアプリは、ユーザーがアプリ内 UI から選んだときだけ取得する。
# 既にインストール済みの AVAILABLE に更新がある場合は、端末が更新 APK を先取りダウンロードできる。
# 応答は短命の presigned URL を返す。
# 端末は WorkManager の download worker に投入し、OkHttp で app-private files に保存する。
# 進行中状態はローカルの download state から UI に反映する。`;

const syncReportCurl = `curl -X POST https://distribution.example.test/api/devices/me/policy_sync_results \\
  -H "Authorization: Bearer $DEVICE_AUTH_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    "device_policy_revision": { "id": 901 },
    "fetched_policy_updated_at": "2026-05-23T10:12:04+09:00",
    "applied_policy_updated_at": "2026-05-23T10:13:20+09:00",
    "actions": [
      { "package_name": "com.example.appa", "action": "INSTALL", "route": "AMAPI_CUSTOM_APP", "result": "INSTALLED" },
      { "package_name": "com.example.appc", "action": "INSTALL", "route": "AMAPI_CUSTOM_APP", "result": "FAILED", "phase": "INSTALL", "code": "SIGNATURE_MISMATCH" },
      { "package_name": "com.example.appb", "action": "INSTALL", "route": "AMAPI_CUSTOM_APP", "result": "FAILED", "phase": "DOWNLOAD", "code": "ARTIFACT_GONE" },
      { "package_name": "com.example.legacy", "action": "UNINSTALL", "route": "PACKAGE_INSTALLER", "result": "UNINSTALLED" }
    ]
  }'

# 1回の sync attempt が「全 work item について 成功 or リカバリ不能な失敗 で確定」した段階でまとめて送る。
# リカバリ可能なエラーはこの一括報告には含めない (端末側でリトライ継続中のため)。
# route は端末が実際に使ったインストール経路。AMAPI SDK custom app install を使えた場合は AMAPI_CUSTOM_APP、PackageInstaller UI を経由した場合は PACKAGE_INSTALLER。
# AMAPI_CUSTOM_APP が使える前提条件は Androidアプリ導入の前提 (/android-app-prereq/#install-axis) を参照。
# phase / code は失敗時のみ。下記 errors テーブル参照。
# 冪等性: device_policy_sync_reports は (device_id, device_policy_revision_id) に UNIQUE 制約を持つ。
# 同じ revision に対する2回目以降の POST はサーバー側で「既存 row の上書き」または「既受領として 200 を返す」で吸収する。
# したがって端末は idempotency-key を送らず、同じ payload をそのまま再送すればよい。`;

const policyFlow = `flowchart TD
  PolicyEdit["管理者 / CIがDevicePolicyを更新<br/>app.id を指定"] --> ServerPolicy["device_policy_revisions<br/>あるべき状態を保存"]
  ServerPolicy --> Push["FCM data message<br/>POLICY_UPDATED"]
  Manual["アプリUIの手動更新"] -.-> Flag["pending_policy_fetch を立てる"]
  Push --> Flag
  Launch["アプリ起動"] --> NeedFetch{"pending_policy_fetch?"}
  NeedFetch -->|はい| Fetch["GET /api/devices/me/policy"]
  NeedFetch -->|いいえ| MaybeSync{"fetched > applied?"}
  Fetch -->|成功| Resolve["サーバーが app_id ごとに<br/>最新リリースを解決して付与"]
  Fetch -->|ネットワーク失敗等| Fail1["pending_policy_fetch を残す<br/>次の機会にリトライ"]
  Resolve --> ClearFlag["pending_policy_fetch を解除<br/>fetched_policy_snapshot 更新"]
  ClearFlag --> MaybeSync
  MaybeSync -->|いいえ| Idle["同期不要"]
  MaybeSync -->|はい| Plan["entry ごとに DOWNLOAD / INSTALL / UNINSTALL を判定"]
  Plan --> DL{"必要な artifact をダウンロード"}
  DL -->|成功 + サイレント可| Apply["インストール / アンインストール実行"]
  DL -->|成功 + ユーザー確認待ち| DownloadedWait["downloaded_artifact_index に保持<br/>INSTALL は利用者確認待ち"]
  DL -->|リカバリ可能な失敗| DLRetry["同じ WorkManager job を retry<br/>次の worker 実行でURL再取得"]
  DL -->|リカバリ不能な失敗| MarkDL["failed_artifacts_blacklist に追記<br/>同じ artifact では再試行しない"]
  Apply -->|成功| MarkOK["installed_package_index を更新"]
  Apply -->|リカバリ可能な失敗| ApplyRetry["何も永続化しない<br/>通知や次回トリガで再試行"]
  Apply -->|リカバリ不能な失敗| MarkAp["failed_artifacts_blacklist に追記<br/>同じ artifact では再試行しない"]
  DownloadedWait --> AllDone
  MarkOK --> AllDone{"全 work item が terminal?"}
  MarkDL --> AllDone
  MarkAp --> AllDone
  AllDone -->|いいえ| Wait["deferred のまま終了<br/>次のトリガで再計算"]
  AllDone -->|はい| Report["pending_report_payload を作成<br/>POST policy_sync_results"]
  Report --> UpdateApplied["applied_policy_snapshot 更新"]`;

const dataModel = `flowchart LR
  subgraph Server["APIサーバー / DB"]
    DP["device_policies<br/>device_id / current_revision_id<br/>updated_at"]
    DPR["device_policy_revisions<br/>id / device_policy_id<br/>created_at"]
    DPE["device_policy_app_entries<br/>device_policy_revision_id / app_id<br/>install_mode"]
    Apps["apps<br/>id / package_name<br/>(hard delete when last release removed)"]
    Releases["releases<br/>app_id / version_code / artifact_id"]
  end

  subgraph DeviceLocal["端末ローカルストア"]
    FetchFlag["pending_policy_fetch<br/>(FCM受信 or 手動更新で立つ)"]
    Fetched["fetched_policy_snapshot<br/>各 entry に install (release info) 付き<br/>updated_at"]
    ActiveDownloads["active_download_jobs<br/>work_name / release_id / version_code / local_path"]
    Downloaded["downloaded_artifact_index<br/>release_id / version_code / local_path / sha256"]
    Failed["failed_artifacts_blacklist<br/>release_id / version_code / failure_phase / failure_code"]
    PendingReport["pending_report_payload<br/>未送信の結果報告"]
    Applied["applied_policy_snapshot<br/>updated_at"]
    Pkgs["installed_package_index<br/>package_name / version_code<br/>installed_by_companion"]
  end

  DP --> DPR --> DPE
  DPE -->|"app_id 参照"| Apps
  Apps -->|"latest release は<br/>fetch 時に解決"| Releases
  DPE -. "GET policy" .-> Fetched
  FetchFlag -. "解除のトリガ" .-> Fetched
  Fetched -. "work list は毎回計算" .-> ActiveDownloads
  ActiveDownloads -. "完了後に検証" .-> Downloaded
  Fetched -. "恒久失敗だけ参照" .-> Failed
  Downloaded -. "DL済み artifact を再利用" .-> Pkgs
  Failed -. "FAILED action の材料" .-> PendingReport
  Pkgs -. "INSTALLED / UNINSTALLED の材料" .-> PendingReport
  PendingReport -. "受理後に更新" .-> Applied
  Pkgs --- Applied`;

const sequence = `sequenceDiagram
  autonumber
  actor Admin as 管理者 / CI
  actor User as デバイス利用者
  participant Api as APIサーバー
  participant Push as FCM
  participant App as コンパニオンアプリ
  participant Local as 端末ローカルストア
  participant Amapi as AMAPI SDK custom app install (route=AMAPI_CUSTOM_APP)
  participant Os as Android PackageInstaller (route=PACKAGE_INSTALLER)

  Admin->>Api: PUT policy (entries は app.id)
  Api->>Api: device_policy_revisions と entries を保存
  Api->>Push: POLICY_UPDATED data message を送信
  Push-->>App: data message、通知表示なし
  App->>Local: pending_policy_fetch を立てる
  Note over App,Local: ここで通信できなくても、フラグは残ったまま

  alt 直後に通信可能
    App->>Api: GET /api/devices/me/policy
  else 失敗したら次の機会
    Note over App: 起動時 / 手動更新 / 再ネットワーク到達で再試行
    App->>Api: GET /api/devices/me/policy
  end
  Api->>Api: 各 entry の app_id から最新release を解決
  Api-->>App: entries に install (release情報) を含めて返す
  App->>Local: pending_policy_fetch を解除 + fetched_policy_snapshot 保存

  Note over App,Local: 以降は fetched > applied の間だけ同期を試みる

  loop 全 work item が terminal になるまで
    App->>App: entry の phase を判定 (DOWNLOAD / INSTALL / UNINSTALL)
    App->>Api: GET /api/releases/:id/artifact_url (必要な entry のみ)
    Api-->>App: 短命 presigned URL
    App->>App: WorkManager download worker に投入<br/>OkHttp で app-private files に保存
    alt ダウンロード成功
      alt AMAPI custom app install の前提を満たす (fully managed + COMPANION_APP role + 対象APK installType=CUSTOM + signingKeyCerts一致 等)
        App->>Amapi: AMAPI SDK でサイレントインストール / アンインストール
        Amapi-->>App: 結果 (成功 or 失敗) → route=AMAPI_CUSTOM_APP
      else 前提を満たさない (managed外 / role未付与 / fingerprint不一致 等)
        App->>App: Sticky通知を維持
        User->>App: 通知タップ
        App->>Os: PackageInstaller UI 起動
        Os-->>App: 結果 → route=PACKAGE_INSTALLER
      end
    App->>Local: installed_package_index を更新
    else ダウンロード失敗 (リカバリ可能)
      Note over App,Local: 同じ WorkManager job を retry。次の worker 実行で artifact_url を取り直して再試行
    else ダウンロード失敗 (リカバリ不能)
      App->>Local: failed_artifacts_blacklist に追記 (phase=DOWNLOAD, code)
    end
  end

  App->>Local: pending_report_payload を作成
  App->>Api: POST policy_sync_results (成功 + リカバリ不能な失敗を一括)
  Api-->>App: 201 Created
  App->>Local: applied_policy_snapshot 更新 + pending_report_payload 破棄`;

const lifecycle = `stateDiagram-v2
  [*] --> Synced
  Synced --> NeedFetch: FCM受信 / 手動更新
  NeedFetch --> NeedFetch: fetch失敗 (リカバリ可能)<br/>次の機会まで待つ
  NeedFetch --> Fetched: fetch成功 (pending_policy_fetch 解除)
  Fetched --> Synced: fetched == applied (差分なし)
  Fetched --> Syncing: fetched > applied
  Syncing --> Syncing: work list を毎回計算<br/>リカバリ可能エラーは永続化しない
  Syncing --> AwaitingUser: AMAPI custom app install 前提を満たさず<br/>+ FORCE_INSTALLED 未達<br/>(PACKAGE_INSTALLER経路でSticky通知を維持)
  AwaitingUser --> Syncing: ユーザーが通知から操作
  Syncing --> Reporting: 全 work item が terminal<br/>pending_report_payload 作成
  Reporting --> Synced: POST policy_sync_results 成功<br/>applied_policy_snapshot 更新
  Reporting --> Reporting: 報告自体が失敗 (リカバリ可能)<br/>次の機会にリトライ
  Synced --> [*]`;
---

<BaseLayout
  title="アプリの配信"
  description="DevicePolicyを app ベースで更新し、端末は必要なときだけ Policy を取得して最新リリースに同期します。失敗はフェーズ別にリトライまたは一括失敗報告します。"
  currentPath="/use-cases/app-distribution/"
>
  <p class="lede">
    アプリ配信は、個別の配信ジョブを端末へ投げる処理ではなく、デバイスごとに1つあるDevicePolicyを更新し、端末がその「あるべき状態」に同期する処理です。
    DevicePolicy が指定するのは <strong>app</strong> (どのアプリを必須/任意で入れるか) であって、特定の release バージョンではありません。配信したいリリースは端末が Policy を取得するたびにサーバーが「その app の最新リリース」を解決して entry に付与します。
    FCM push はユーザー向けの通知ではなく、端末側の <code>pending_policy_fetch</code> フラグを立てる契機にのみ使います。Policy 取得は「フラグが立っているとき」だけ行い、起動の度に毎回叩くわけではありません。
    Fetch / Download / Install のどこで失敗するかで取り扱いを分け、リカバリ可能なエラーは該当フェーズだけリトライし、リカバリ不能なエラーは entry 単位で「失敗」と確定してまとめてサーバーへ報告します。
  </p>

  <section aria-labelledby="actors">
    <p class="section-kicker">Actors and responsibilities</p>
    <h2 id="actors">登場人物と責務</h2>
    <div class="table-wrap">
      <table class="usa-table">
        <thead>
          <tr>
            <th scope="col">登場人物</th>
            <th scope="col">きっかけ</th>
            <th scope="col">責務</th>
            <th scope="col">触るリソース</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <th scope="row">管理者 / CI</th>
            <td>デバイスへ配るアプリ構成を変えたい</td>
            <td>管理画面で DevicePolicy を更新する。entry は app と install_mode のみで、release / version は指定しない。APKアップロード後に既存 policy の revision だけを進めたい場合は POST /admin/apps/:package_name/touch_policies を呼ぶ。</td>
            <td>device_policies, device_policy_revisions, device_policy_app_entries</td>
          </tr>
          <tr>
            <th scope="row">APIサーバー</th>
            <td>POST /admin/apps/:package_name/touch_policies / GET /api/devices/me/policy / POST /api/devices/me/policy_sync_results</td>
            <td>Policy更新を不変revisionとして保存し、FCM data messageを送信。GET時に各 entry の app_id から最新release を解決して install フィールドに乗せる。app が hard delete されると関連 entry も CASCADE 削除されるため、端末向け Policy 応答に「削除されたアプリ」は現れない。一括失敗報告 (policy_sync_results) を受領して監査ログに残す。</td>
            <td>device_policies, device_policy_revisions, device_policy_app_entries, apps, releases, device_policy_sync_reports, fcm_push_tokens</td>
          </tr>
          <tr>
            <th scope="row">FCM</th>
            <td>APIサーバーからのsend</td>
            <td>data message を端末アプリへ届ける。data 内容は POLICY_UPDATED と identifier、updated_at のみ。</td>
            <td>FCM data payload (notification payload は使わない)</td>
          </tr>
          <tr>
            <th scope="row">コンパニオンアプリ</th>
            <td>FCM受信 / 手動更新 / 再ネットワーク到達 / アプリ起動 (フラグがある時のみ fetch)</td>
            <td>pending_policy_fetch / fetched_policy_snapshot / installed_package_index / failed_artifacts_blacklist / pending_report_payload / applied_policy_snapshot を管理する。work item の進捗は永続化せず、フェーズ別にリトライ判定し、確定したら一括で結果を報告する。</td>
            <td>端末ローカルストア各種, PackageInstaller (route=PACKAGE_INSTALLER) / AMAPI SDK custom app install (route=AMAPI_CUSTOM_APP)</td>
          </tr>
          <tr>
            <th scope="row">端末利用者</th>
            <td>(<code>AMAPI_CUSTOM_APP</code> 経路では介在しない) / (<code>PACKAGE_INSTALLER</code> 経路で) Sticky通知タップ</td>
            <td>AMAPI custom app install の前提を満たさず自動インストールできない端末で、先取り済みAPKまたはその場のDOWNLOADからPackageInstaller UIへ進む。任意アプリ (AVAILABLE) の未導入は経路によらずアプリUI内から自分で選んで入れるが、既に入っているAVAILABLEの更新APKは先取りできる。</td>
            <td>PackageInstaller UI</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section aria-labelledby="data-model">
    <p class="section-kicker">Data model</p>
    <h2 id="data-model">DevicePolicy と端末ローカルストアの関係</h2>
    <Mermaid chart={dataModel} title="サーバー側のdevice_policy_*、apps、releases と端末側のフラグ・スナップショット・entry状態の関係" />
    <dl class="key-value-list">
      <div>
        <dt>device_policies / device_policy_revisions / device_policy_app_entries</dt>
        <dd>device 1つにつき 1 device_policy。Policy 更新は新しい不変 revision の追加で表現する。entries は app_id と install_mode のみで、release_id や version_code は持たない。配信すべきリリースは GET 時にサーバーが apps.id から最新版を解決する。</dd>
      </div>
      <div>
        <dt>apps</dt>
        <dd>package_name で識別される配布対象アプリの identity。全ての関連 release が削除された時点で <strong>hard delete</strong> し、関連 <code>device_policy_app_entries</code> も FK CASCADE で同時に削除される。再アップロード時は同じ <code>package_name</code> でも <strong>別の <code>apps.id</code> として新規作成</strong> される (旧 id の復活はしない)。</dd>
      </div>
      <div>
        <dt>pending_policy_fetch (端末ローカル)</dt>
        <dd>boolean。FCM data message を受け取った時、またはユーザーが手動更新を要求した時に true にする。GET /api/devices/me/policy が成功して fetched_policy_snapshot を保存できた瞬間に false に戻す。端末はこのフラグが true のときだけ Policy 取得を試みる (起動するたびに毎回 fetch するわけではない)。FCM を取りこぼした端末は、利用者がアプリを明示起動して手動更新することで復旧する。</dd>
      </div>
      <div>
        <dt>fetched_policy_snapshot (端末ローカル)</dt>
        <dd>サーバーから最後に取得できた Policy 本文 (各 entry に install を含む)。fetch が成功するたびに置き換える。</dd>
      </div>
      <div>
        <dt>active_download_jobs / downloaded_artifact_index / failed_artifacts_blacklist (端末ローカル)</dt>
        <dd><code>active_download_jobs</code> は WorkManager unique work を release.id + version_code に紐づける一時的な参照で、同じ artifact の重複ダウンロードを防ぎ、UI に進行中状態を出すためだけに使う。download worker は短命 artifact_url を各 retry で取り直し、OkHttp で app-private files に保存する。worker が非リトライ失敗または明示キャンセルになった時点で消す。active_download_jobs には「DOWNLOAD後にINSTALLへ進めるか」も保存し、アプリ起動時やPolicy表示時に端末の実インストール状態と突き合わせる。必要 version が既に入っていれば stale record を消し、<code>INSTALLING</code> のまま対象アプリが消えていてAPK bytesが残る場合は <code>downloaded_artifact_index</code> に戻す。さらに同じ WorkManager unique work 名を <code>ExistingWorkPolicy.KEEP</code> で再投入して、失われた途中処理だけを復旧する。PACKAGE_INSTALLER 経路でユーザー確認待ちにする場合は、ダウンロード完了時点で <code>downloaded_artifact_index</code> に移し、APK bytes を app-private files に残す。ユーザーがPackageInstaller確認UIをキャンセルした場合も <code>downloaded_artifact_index</code> に戻し、次回は保存済みAPKから再開する。<code>downloaded_artifact_index</code> は再利用できる artifact、<code>failed_artifacts_blacklist</code> は「同じ条件で結果が変わらない」と確定した失敗事実だけを保持する。リカバリ可能な失敗では active_download_jobs を retry 対象の一時参照として残し、次の worker 実行で fetched_policy_snapshot・installed_package_index・failed_artifacts_blacklist から work list を再計算する。</dd>
      </div>
      <div>
        <dt>pending_report_payload (端末ローカル)</dt>
        <dd>全 work item が terminal になった瞬間に作る未送信の policy_sync_results 本文。報告が失敗した場合はこの payload を保持し、次の機会に同じ内容を冪等再送する。</dd>
      </div>
      <div>
        <dt>applied_policy_snapshot (端末ローカル)</dt>
        <dd>「全 work item が terminal になり、一括報告まで完了した時点」の Policy。fetched_policy_snapshot からの完全コピーで置き換える。報告途中・deferred が残る段階では更新しない。</dd>
      </div>
      <div>
        <dt>installed_package_index (端末ローカル)</dt>
        <dd>端末上の package_name、version_code、installed_by_companion。「ユーザーが他経路で入れた」と「このアプリが入れた」を区別し、UNINSTALL対象を絞り込む。</dd>
      </div>
    </dl>
  </section>

  <section aria-labelledby="distribution-flow">
    <p class="section-kicker">Flow with data</p>
    <h2 id="distribution-flow">処理フロー</h2>

    <article class="flow-step" aria-labelledby="step-1">
      <div class="flow-step__header">
        <span class="flow-step__number">1</span>
        <div>
          <h3 id="step-1">管理者がデバイスのDevicePolicyを更新する</h3>
          <p>1デバイスにつき1つのDevicePolicyを持ちます。entry には app.id と install_mode のみを指定し、配信するリリースを指定しません。「このアプリは必須」「このアプリは任意」というあるべき状態だけを宣言し、実際のリリース解決はサーバーが GET 時に行います。Policy更新は新しい revision の追加であり、過去 revision は不変です。編集画面 (Bootstrap 管理 UI) は登録済みアプリを全行表示し、各行の <code>Include</code> チェックと <code>FORCE_INSTALLED</code> / <code>AVAILABLE</code> の切り替えで構成を決め、「Publish new revision」で新しい revision を発行します。</p>
        </div>
      </div>
      <div class="flow-step__grid">
        <div>
          <DiagramFrame src="/mocks/app-distribution/step-1-policy-editor.html" title="管理画面 (Web): デバイスのポリシー編集" />
        </div>
        <div class="flow-step__details">
          <h4>管理画面での更新</h4>
          <pre class="curl-block"><code>{policyEditorBehavior}</code></pre>
          <h4>保存される revision の例</h4>
          <pre class="curl-block"><code>{policyEditorRevision}</code></pre>
          <h4>REST APIの場合 (curl): 既存 policy revision の更新</h4>
          <pre class="curl-block"><code>{touchPoliciesCurl}</code></pre>
          <h4>CLIツールの場合: 既存 policy revision の更新</h4>
          <pre class="curl-block"><code>{touchPoliciesCli}</code></pre>
          <h4>応答</h4>
          <pre class="curl-block"><code>{touchPoliciesResponse}</code></pre>
          <h4>作成・更新されるDBデータ</h4>
          <dl class="db-list">
            <div>
              <dt>device_policies / device_policy_revisions / device_policy_app_entries</dt>
              <dd>管理画面での編集では、選択された app が現存することを確認してから新しい revision を作成し entries を保存する。version_code や release_id は格納しない。<code>POST /admin/apps/:package_name/touch_policies</code> は entries を変更せず、指定 app を含む current revision をコピーして新しい revision にする。FCM data message も同期的に送信する (送信失敗してもログだけ取り、Policy は変更しない)。FCM が届かなかった端末は、利用者のアプリ明示起動または手動更新で復旧する。</dd>
            </div>
          </dl>
          <h4>過去 revision の扱い</h4>
          <p>過去 revision は不変 (admin による上書きはしない)。ただし、関連 app が hard delete された場合は FK CASCADE で過去 revision の該当 entry も削除される (= 「削除されたアプリの履歴」は残らない)。差し戻しは古い revision を current にし直すのではなく、同じ内容で新しい revision を作る。</p>
          <h4>存在しないアプリ参照のルール</h4>
          <p>管理画面で新しい revision を作るときは、現在登録されているアプリだけを選択肢に出す。<code>POST /admin/apps/:package_name/touch_policies</code> は package_name が見つからない場合に 404 APP_NOT_FOUND を返す。アプリは hard delete されるため「削除済みだが参照は残る」状態は存在しない。</p>
        </div>
      </div>
    </article>

    <article class="flow-step" aria-labelledby="step-2">
      <div class="flow-step__header">
        <span class="flow-step__number">2</span>
        <div>
          <h3 id="step-2">FCM push を契機に pending_policy_fetch を立て、可能なときに Policy を取得する</h3>
          <p>FCM は data message として Policy 更新だけを届けます。端末はこの受信で <code>pending_policy_fetch</code> フラグを立て、それ以後の最初に Policy API を呼べる機会 (直後に通信できればその場で、ダメなら次のオンライン到達時、再起動時、アプリ明示起動時など) で GET を1回試みます。<strong>起動するたびに無条件で fetch することはしません</strong>。fetch が失敗してもフラグは立ったままにし、次の機会に再試行します。fetch が成功して fetched_policy_snapshot を上書きした瞬間に、フラグを下ろします。FCM が届かなかった端末は自動では気づけないため、利用者がアプリを開いて手動更新したときに復旧できればよい、という前提にします。取得した Policy はホーム画面に「ポリシーで指定されたアプリ」一覧 (全 entries を1リスト) として表示され、FORCE_INSTALLED の行には「必須」チップ、各行にバージョンと状態 (インストール済み / 内容に更新あり / ダウンロード中…) が出ます。ホーム画面を下に引っ張ると <code>pending_policy_fetch</code> を立てて手動で再取得します。</p>
        </div>
      </div>
      <div class="flow-step__grid">
        <div>
          <DiagramFrame src="/mocks/app-distribution/step-2-policy-fetch.html" title="コンパニオンアプリ: ホーム画面 (取得した配信ポリシーの一覧)" />
        </div>
        <div class="flow-step__details">
          <h4>FCM data message</h4>
          <pre class="curl-block"><code>{fcmDataMessage}</code></pre>
          <h4>Policy 取得 API 呼び出し</h4>
          <pre class="curl-block"><code>{fetchPolicyCurl}</code></pre>
          <h4>応答</h4>
          <pre class="curl-block"><code>{fetchPolicyResponse}</code></pre>
          <h4>端末ローカルデータの扱い</h4>
          <dl class="db-list">
            <div>
              <dt>pending_policy_fetch</dt>
              <dd>FCM 受信または手動更新で true。GET 成功 → fetched_policy_snapshot 保存 が完了した瞬間に false。GET 失敗 (タイムアウト、5xx、ネットワーク不到達、認証エラー以外の一時的失敗) では true のまま。</dd>
            </div>
            <div>
              <dt>fetched_policy_snapshot</dt>
              <dd>取得した Policy 本文 (install 付き) で上書き。サーバー側の device_policy_revisions は読み取りだけで変更しない。</dd>
            </div>
            <div>
              <dt>failed_artifacts_blacklist</dt>
              <dd>fetched_policy_snapshot が置き換わっても、同じ release.id + version_code に対する恒久失敗だけ参照する。release.id や version_code が変わっていれば blacklist はヒットせず、新しい artifact として試す。fetched_policy_snapshot に出てこなくなった release.id の blacklist は cleanup してよい。</dd>
            </div>
            <div>
              <dt>applied_policy_snapshot</dt>
              <dd>この時点では更新しない。fetched との差で「同期がまだ要る」と判断する。</dd>
            </div>
            <div>
              <dt>削除アプリの扱い</dt>
              <dd>サーバー側で app が hard delete された時点で関連 entry も CASCADE 削除される。端末向け Policy 応答には現れず、端末側で「削除されたアプリ」を意識する必要はない。</dd>
            </div>
            <div>
              <dt>端末通知</dt>
              <dd>FCM data message 受信そのものでは表示しない。Sticky 通知は後続ステップ (軸B = <code>PACKAGE_INSTALLER</code> で FORCE_INSTALLED 未達) のときだけ出す。</dd>
            </div>
          </dl>
        </div>
      </div>
    </article>

    <article class="flow-step" aria-labelledby="step-3">
      <div class="flow-step__header">
        <span class="flow-step__number">3</span>
        <div>
          <h3 id="step-3">entry ごとに DOWNLOAD と INSTALL を進め、リカバリ可能な失敗はリトライする</h3>
          <p>fetched_policy_snapshot &gt; applied_policy_snapshot のとき同期を試みます。比較するのは「Policy の install.version_code / artifact_sha256」と「端末上の installed package の versionCode / APK checksum」。オンプレの配信サーバーは常時到達できるとは限らないため、端末は Policy 取得直後の到達可能なタイミングで APK bytes をできるだけ早く確保します。FORCE_INSTALLED は未インストールでも更新でも自動で DOWNLOAD を開始します。AVAILABLE は初回導入までは自動 DOWNLOAD しませんが、既に端末に入っているアプリに更新がある場合は UPDATE 用 artifact を自動 DOWNLOAD します。同期は永続的な entry 進捗ではなく、毎反復で計算する <strong>work list</strong> として扱います。work list は fetched_policy_snapshot、installed_package_index、active_download_jobs、downloaded_artifact_index、failed_artifacts_blacklist からその場で作り、各 work item を1回進めます。既に同じ release.id + version_code の active_download_jobs または downloaded_artifact_index がある場合は新しい DOWNLOAD を enqueue せず、ローカル download state を UI に反映して待ちます。リカバリ可能な失敗では同じ WorkManager job が artifact URL を取り直して retry します。リカバリ不能な失敗だけ failed_artifacts_blacklist に追記し、以後は同じ artifact では再試行しません。利用者がホームの行をタップするとアプリ詳細画面に入り、状態に応じて「インストール」/「アップデート」/「アンインストール」ボタンが出ます。ダウンロード進行中はボタンを無効化し、本文に「ダウンロード中 NN%」、ボタンに「ダウンロード中」(完了直前は「インストール準備中」) を表示します。ダウンロード完了後は「ダウンロード済み」と表示し、利用者の確認操作では保存済みAPKを PackageInstaller / AMAPI custom app install に渡すため、サーバーへ再接続しません。</p>
        </div>
      </div>
      <div class="flow-step__grid">
        <div>
          <DiagramFrame src="/mocks/app-distribution/step-3-sync-plan.html" title="コンパニオンアプリ: アプリ詳細 (ダウンロード進行中)" />
        </div>
        <div class="flow-step__details">
          <h4>必要なときだけ artifact URL を取得する</h4>
          <pre class="curl-block"><code>{downloadUrlCurl}</code></pre>
          <h4>同期対象の決め方</h4>
          <dl class="db-list">
            <div>
              <dt>INSTALL対象</dt>
              <dd>FORCE_INSTALLED かつ「未インストール」または「インストール済み version_code &lt; Policy install.version_code」または「同じ version_code だが端末上の APK checksum と Policy install.artifact_sha256 が異なる」の entry。PACKAGE_INSTALLER 経路では DOWNLOAD だけ先に完了させ、INSTALL は利用者確認待ちにできる。</dd>
            </div>
            <div>
              <dt>DOWNLOAD進行中の扱い</dt>
              <dd>同じ release.id + version_code の active_download_jobs がある entry は、ローカル download state をホームの行 (白背景) とアプリ詳細の CTA に反映し、インストール操作を無効化する。downloaded_artifact_index がある entry は「ダウンロード済み」として表示し、利用者操作時は保存済みAPKを使う。利用者が同じ行を何度タップしても、同じ APK を重複して enqueue しない。</dd>
            </div>
            <div>
              <dt>UNINSTALL対象</dt>
              <dd>Policy entries に存在せず、かつ <code>installed_by_companion = true</code> の package。PolicyにAVAILABLEとして残るアプリは削除しない。ユーザーが他経路で入れたものは触らない。</dd>
            </div>
            <div>
              <dt>SHOW対象 (AVAILABLE)</dt>
              <dd>ホームの一覧 (DevicePolicy 全 entries を 1 リストで表示) に並べる。未インストールの AVAILABLE は自動 DOWNLOAD / INSTALL しない。既に端末にインストール済みで更新が必要な AVAILABLE は、サーバー到達中に artifact だけ自動 DOWNLOAD するが INSTALL は利用者操作まで進めない。AVAILABLE entry は自動インストールの work list には含めず、policy_sync_results にも含めない。device 用の GET /admin/apps は追加しない (admin 用のみ)。</dd>
            </div>
          </dl>
          <h4>リカバリ可能 / 不能の判定</h4>
          <dl class="db-list">
            <div>
              <dt>リカバリ可能 (DOWNLOAD フェーズ)</dt>
              <dd>ネットワークタイムアウト、5xx、TLS 接続失敗、artifact_url 期限切れ (再取得すれば良い)、端末ストレージ一時不足 → 同じ WorkManager job を retry し、次の worker 実行で同じ install.release.id から artifact_url を取り直す。</dd>
            </div>
            <div>
              <dt>リカバリ不能 (DOWNLOAD フェーズ)</dt>
              <dd>release が削除されて 404 が返り続ける (ARTIFACT_GONE)、sha256 不一致 (ARTIFACT_CORRUPTED) など、その install.release.id に対してリトライしても結果が変わらないもの → failed_artifacts_blacklist に追記。同じ release.id + version_code では再試行しない。</dd>
            </div>
            <div>
              <dt>リカバリ可能 (INSTALL フェーズ)</dt>
              <dd><code>PACKAGE_INSTALLER</code> 経路で Sticky 通知を維持 (ユーザーが反応すればインストール進行)、PackageInstaller の "in use" 一時エラー、<code>AMAPI_CUSTOM_APP</code> 経路の IssueCommand 一時エラーなど → 何も永続化しない。downloaded_artifact_index に artifact が残っていれば、次の work list 再計算で DOWNLOAD は飛ばして INSTALL から再試行する。</dd>
            </div>
            <div>
              <dt>リカバリ不能 (INSTALL フェーズ)</dt>
              <dd>署名不一致 (SIGNATURE_MISMATCH)、minSdk 不足 (INCOMPATIBLE_OS)、VERSION_DOWNGRADE など、その artifact で再試行しても結果が変わらないもの → failed_artifacts_blacklist に追記。</dd>
            </div>
          </dl>
          <h4>artifact_url の有効期限</h4>
          <p>artifact_url は短命 URL とし、初期値は15分を目安にする。APKのダウンロードは WorkManager download worker が OkHttp で app-private files に streaming し、retry ごとに artifact_url を取り直す。部分ファイルが残っていて配信元が HTTP Range を受け付ける場合は途中から再開し、受け付けない場合は同じ release.id の artifact_url で最初から再ダウンロードする。</p>
          <h4>確定判定</h4>
          <p>FORCE_INSTALLED / UNINSTALL の全 work item が terminal (成功、または failed_artifacts_blacklist へ追記済み) になるまで sync attempt は終わらない。リカバリ可能な失敗で deferred になった work item がある場合、確定判定には到達しないため一括報告も applied 更新も行わない。次の機会 (再ネットワーク到達、起動、手動更新) に work list を再計算して該当フェーズから再試行する。</p>
        </div>
      </div>
    </article>

    <article class="flow-step" aria-labelledby="step-4">
      <div class="flow-step__header">
        <span class="flow-step__number">4</span>
        <div>
          <h3 id="step-4">確定した結果をまとめて報告し、applied_policy_snapshot を更新する</h3>
          <p>全 work item が terminal になったら、成功した work item と <strong>リカバリ不能な失敗だけ</strong>を一括で POST します。リカバリ可能な失敗で deferred になった work item は報告対象に含めません (=端末がリトライ継続中であることを意味する)。報告本文は送信前に <code>pending_report_payload</code> として保存し、報告が 201 で受理されたら applied_policy_snapshot を更新して payload を破棄します。報告自体が失敗した場合は次の機会に同じペイロードで再送します。FORCE_INSTALLED が PACKAGE_INSTALLER 経路で未達のあいだは、アプリごとに消去不可 (ongoing) の常駐通知を出します。通知本文をタップするとアプリ詳細が開き、通知の「インストール」アクションを押すと、ダウンロード済みAPKがあれば即座に PackageInstaller UI へ進み、未取得ならその場で DOWNLOAD を開始します (通知に「あとで」等の他アクションは持たせません)。INSTALL が確定 (成功 or リカバリ不能失敗) したら通知を下げます。</p>
        </div>
      </div>
      <div class="flow-step__grid">
        <div>
          <DiagramFrame src="/mocks/app-distribution/step-4-install-route.html" title="スマートフォン: 必須アプリのインストールを促す常駐通知" />
        </div>
        <div class="flow-step__details">
          <h4>一括結果報告</h4>
          <pre class="curl-block"><code>{syncReportCurl}</code></pre>
          <h4>記録するデータ</h4>
          <dl class="db-list">
            <div>
              <dt>applied_policy_snapshot (端末)</dt>
              <dd>policy_sync_results が 201 で受け付けられた直後に、fetched_policy_snapshot からコピーで上書き。部分成功でも (失敗が確定済みであれば) 更新する。これにより「処理は終わったが一部失敗が残っている状態」を「fetched == applied」で表現できる。</dd>
            </div>
            <div>
              <dt>pending_report_payload (端末)</dt>
              <dd>全 work item が terminal になった瞬間に作成し、POST が 201 または冪等な 200 で受理されたら破棄する。5xx / IO では保持して同じ payload を再送する。</dd>
            </div>
            <div>
              <dt>failed_artifacts_blacklist (端末)</dt>
              <dd>リカバリ不能な失敗事実だけ保持する。報告完了後も同じ release.id + version_code では再試行しない判断材料として残し、次回 fetch で release.id が変わったらヒットしなくなる。</dd>
            </div>
            <div>
              <dt>Sticky install notification (端末)</dt>
              <dd>軸B = <code>PACKAGE_INSTALLER</code> で FORCE_INSTALLED が未達かつ未確定の場合だけ表示する。INSTALL が確定 (成功 or リカバリ不能失敗) したら下げる。</dd>
            </div>
            <div>
              <dt>device_policy_sync_reports (サーバー)</dt>
              <dd>device_policy_revision_id、actions[]、reported_at を保存する。actions の各エントリは <code>{`package_name, action, route, result, phase?, code?`}</code> を持つ。<code>(device_id, device_policy_revision_id)</code> に UNIQUE 制約を置き、同じ revision に対する再送は冪等に吸収する (新規受領なら 201、既受領なら 200 を返す)。Policy 本体は書き換えない。</dd>
            </div>
            <div>
              <dt>fcm_push_tokens / releases / artifacts</dt>
              <dd>同期結果報告では更新しない。</dd>
            </div>
          </dl>
        </div>
      </div>
    </article>
  </section>

  <section aria-labelledby="ownership">
    <p class="section-kicker">Data ownership</p>
    <h2 id="ownership">Policy同期で誰がどのデータを持つか</h2>
    <Mermaid chart={policyFlow} title="DevicePolicy更新から端末同期完了まで (リトライとリカバリ可能/不能の分岐を含む)" />
    <div class="table-wrap">
      <table class="usa-table">
        <thead>
          <tr>
            <th scope="col">データ</th>
            <th scope="col">保持場所</th>
            <th scope="col">用途</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <th scope="row">DevicePolicy (app_id ベース)</th>
            <td>サーバーの device_policies / device_policy_revisions / device_policy_app_entries</td>
            <td>1デバイスのあるべきアプリ状態を app 単位で表す。release / version は持たない。</td>
          </tr>
          <tr>
            <th scope="row">install (release.id, version_code, version_name, artifact_sha256)</th>
            <td>サーバーが GET 応答時に各 entry へ付与</td>
            <td>その時点で配信すべき具体的リリース。サーバーが apps.id から「最新release」を解決した結果。DB には保存せず、毎回の GET で算出する。</td>
          </tr>
          <tr>
            <th scope="row">apps の hard delete</th>
            <td>apps テーブル + FK CASCADE</td>
            <td>全ての関連release が削除された時点で行を消す。<code>device_policy_app_entries</code> も同時に CASCADE 削除されるため、admin/device の Policy GET 応答で「削除されたアプリ」状態は発生しない。同じ <code>package_name</code> の再アップロードは別 <code>apps.id</code> での新規作成として扱う。</td>
          </tr>
          <tr>
            <th scope="row">pending_policy_fetch</th>
            <td>端末ローカル</td>
            <td>「Policy 取得が必要」というフラグ。FCM 受信や手動更新で立ち、fetch 成功で下がる。起動時は無条件 fetch ではなくこのフラグだけを見て判断する。</td>
          </tr>
          <tr>
            <th scope="row">fetched_policy_snapshot</th>
            <td>端末ローカル</td>
            <td>最後に成功した fetch の結果。各 entry に install (release情報) 付き。</td>
          </tr>
          <tr>
            <th scope="row">active_download_jobs / downloaded_artifact_index / failed_artifacts_blacklist</th>
            <td>端末ローカル</td>
            <td>WorkManager download worker、DL済み artifact、同じ条件では結果が変わらない恒久失敗を保持する。active_download_jobs は重複 enqueue 防止とUI反映のための一時参照で、起動時の復旧対象でもある。非リトライ失敗・明示キャンセル・インストール成功・リカバリ不能なインストール失敗では消す。downloaded_artifact_index はユーザー確認待ちのPackageInstaller経路、PackageInstaller UI のユーザーキャンセル、AVAILABLE更新で、サーバー再接続なしに後続INSTALLへ進むために残す。</td>
          </tr>
          <tr>
            <th scope="row">applied_policy_snapshot</th>
            <td>端末ローカル</td>
            <td>「全 work item が terminal になり、結果を一括報告し終えた」時点の Policy。fetched との一致で「同期完了」を表す。</td>
          </tr>
          <tr>
            <th scope="row">installed_by_companion</th>
            <td>端末ローカルの installed_package_index</td>
            <td>Policy から消えたアプリを削除してよいか判断。このアプリが入れたものだけ削除対象にする。</td>
          </tr>
          <tr>
            <th scope="row">device_policy_sync_reports</th>
            <td>サーバー</td>
            <td>各 revision に対する端末側の同期結果ログ。actions 内の各 entry が phase / code を持つ。Policy 本体は書き換えない。</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section aria-labelledby="sequence">
    <p class="section-kicker">Sequence</p>
    <h2 id="sequence">配信時の責務分担</h2>
    <Mermaid chart={sequence} title="管理者、APIサーバー、FCM、コンパニオンアプリ、Androidの関係 (リトライ含む)" />
  </section>

  <section aria-labelledby="lifecycle">
    <p class="section-kicker">Lifecycle</p>
    <h2 id="lifecycle">端末内Policy同期のライフサイクル</h2>
    <Mermaid chart={lifecycle} title="pending_policy_fetch / fetched / work list / applied のライフサイクル" />
    <p>Policy revision と sync report は append-only。<strong>MVPでは削除ジョブは持たず、テーブル単位で物理的に保持する</strong> (将来の保持期間チューニング / アーカイブ移送は別ユースケース)。テーブル分離 (<code>device_policies</code>, <code>device_policy_revisions</code>, <code>device_policy_app_entries</code>, <code>device_policy_sync_reports</code> がそれぞれ独立) によって、後から保持期間別の cleanup ジョブを追加できる構成にしておく。</p>
  </section>

  <section aria-labelledby="errors">
    <p class="section-kicker">Errors</p>
    <h2 id="errors">主要エラーと応答</h2>
    <p>失敗はフェーズ別に「リカバリ可能 (端末が同じフェーズからリトライ)」と「リカバリ不能 (failed_artifacts_blacklist に追記して一括報告)」に分けます。サーバー側の policy_sync_results はリカバリ不能な失敗だけが届く想定で、リカバリ可能な失敗で同じレポートが何度も来ることはありません。</p>
    <div class="table-wrap">
      <table class="usa-table">
        <thead>
          <tr>
            <th scope="col">状況</th>
            <th scope="col">HTTP / code</th>
            <th scope="col">サーバー側の扱い</th>
            <th scope="col">端末 / 管理者側の扱い</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <th scope="row">device_auth_token が無効 / 期限切れ</th>
            <td>401 DEVICE_AUTH_REQUIRED</td>
            <td>fcm_push_tokens は触らない。Policy更新もできない。</td>
            <td>クライアント側で再登録導線を出す。registration tokenの再発行を管理者に依頼する。リトライ自体は無意味なので pending_policy_fetch は解除しない (再登録後に再試行)。</td>
          </tr>
          <tr>
            <th scope="row">FCM 受信後、GET policy が失敗 (タイムアウト / 5xx / ネットワーク不到達)</th>
            <td>—</td>
            <td>送信は完了済み、サーバーは何もしない。</td>
            <td>pending_policy_fetch は true のまま維持。次の機会 (再オンライン、再起動、手動更新) に再試行。</td>
          </tr>
          <tr>
            <th scope="row">DevicePolicy がまだ作られていない端末が Policy を取りに来た</th>
            <td>200 OK (空のentries)</td>
            <td>空のentriesで返す。</td>
            <td>installed_by_companion のアプリは全て UNINSTALL 候補になる。pending_policy_fetch は解除する。</td>
          </tr>
          <tr>
            <th scope="row">touch_policies で存在しない package_name を指定</th>
            <td>404 APP_NOT_FOUND</td>
            <td>Policy は変更しない。entries は前回 revision のまま。</td>
            <td>GET /admin/apps で現存する package_name を確認してから再実行する。最後の release を消して app が hard delete された場合は、APKを再アップロードしてから policy を再構成する。</td>
          </tr>
          <tr>
            <th scope="row">artifact_url の DL がリカバリ可能な失敗 (5xx / TLS / タイムアウト / 期限切れ)</th>
            <td>(DL先 5xx) / 403 SignatureDoesNotMatch 等</td>
            <td>presigned URL を短命に発行する。期限切れは再取得 (/api/releases/:id/artifact_url) で対応可能。</td>
            <td>同じ WorkManager job を retry し、次の worker 実行で同じ install.release.id の artifact_url を再取得 → 再ダウンロード。policy_sync_results には含めない。</td>
          </tr>
          <tr>
            <th scope="row">artifact_url の DL がリカバリ不能な失敗 (release削除直後で 404 が続く / sha256不一致)</th>
            <td>404 RELEASE_NOT_FOUND など</td>
            <td>—</td>
            <td>failed_artifacts_blacklist に追記 (phase=DOWNLOAD, code=ARTIFACT_GONE or ARTIFACT_CORRUPTED)。一括報告に含める。同 install.release.id では再試行しない。次回 fetch で release.id か version_code が変わったら再試行可能。</td>
          </tr>
          <tr>
            <th scope="row">AMAPI custom app install の前提を満たさず (= 軸B が <code>PACKAGE_INSTALLER</code>) + FORCE_INSTALLED 未達</th>
            <td>(該当なし)</td>
            <td>—</td>
            <td>到達可能なうちにAPKをDOWNLOADして downloaded_artifact_index に残し、Sticky 通知を維持。work item は deferred (= リカバリ可能扱い)。ユーザーが通知から確認画面に進むと、ダウンロード済みAPKがあればサーバー再接続なしでPackageInstaller UIへ進む。未取得ならその場でDOWNLOADを試みる。一括報告も applied 更新もしない。前提条件は <a href="/android-app-prereq/#install-axis">Androidアプリ導入の前提 #インストール経路という独立した軸</a> を参照。</td>
          </tr>
          <tr>
            <th scope="row">INSTALL がリカバリ不能な失敗 (署名不一致 / OS 非互換 / ユーザーが明示拒否)</th>
            <td>(該当なし、結果報告で表現)</td>
            <td>device_policy_sync_reports に actions[].result=FAILED で記録。Policy本体は変えない。</td>
            <td>failed_artifacts_blacklist に追記 (phase=INSTALL, code=SIGNATURE_MISMATCH など)。一括報告に含める。同じ artifact では再試行しない。管理者に再リリースを依頼する。</td>
          </tr>
          <tr>
            <th scope="row">policy_sync_results 自体の POST が失敗</th>
            <td>—</td>
            <td>—</td>
            <td>送信ペイロードはローカルに保持し、次の機会に同じ内容で再送 (冪等扱い)。applied_policy_snapshot は受理されるまで更新しない。</td>
          </tr>
          <tr>
            <th scope="row">同期中に Policy がさらに更新された (revision跳び)</th>
            <td>—</td>
            <td>最新revisionが正。古いrevisionに対する結果報告も受け付けるが、applied snapshotに反映するかは端末判断。</td>
            <td>FCM 再受信で pending_policy_fetch が立つ。途中の同期は最後まで進めても、次の fetch で fetched が更新され、work list は永続データから再計算される。</td>
          </tr>
          <tr>
            <th scope="row">同じ version_code で artifact が更新された</th>
            <td>—</td>
            <td>新しい release.id と artifact_sha256 が返る。version_code は同じ。</td>
            <td>端末は version_code が同じでも artifact_sha256 が端末上の APK checksum と異なれば更新する。version_name のみが変わった場合は同期不要。</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section aria-labelledby="guidance">
    <p class="section-kicker">Out-of-spec guidance</p>
    <h2 id="guidance">不足ユースケースに遭遇したときの判断指針</h2>
    <p>このページに書かれていないケースは、まず次の原則で判断してください。</p>
    <ol>
      <li><strong>「あるべき状態 (Policy)」と「実際の状態 (端末)」の差分で考える。</strong> 個別のジョブやキューを作らない。新しい配信要件が出たら、まずPolicyのスキーマで表現できないかを検討する。</li>
      <li><strong>DevicePolicy は app 単位、release は引かない。</strong> 「このデバイスにこの version を固定したい」要件は、Policy が release を指す形ではなく、別の "pinning" 概念を後付けする形で考える。今の Policy 設計は「最新版を配信する」を基本にする。</li>
      <li><strong>release 削除 → app の最後の release が消えれば app も hard delete。</strong> Policy entries も同時に FK CASCADE で消える。「削除されたアプリ」状態 (entry は残るが app が無い) は作らない。</li>
      <li><strong>app が消えた package を再アップロードしたら別の app.id になる。</strong> 同じ <code>package_name</code> でも別 id。古い entry は既に CASCADE で消えているので、配信を続けたい場合は admin が新しい app.id で entry を作り直す。</li>
      <li><strong>app の hard delete で端末は UNINSTALL 候補になる。</strong> 端末から見ると Policy 不在になるため、<code>installed_by_companion=true</code> の既存インストールは UNINSTALL 候補になる。これは「配布元から全 release が削除されたアプリは配信対象外に戻す」という運用判断として扱う。</li>
      <li><strong>Policy 取得は必要なときだけ。</strong> 起動時に毎回叩かない。FCM 受信 / 手動更新 / 報告未送信 などで立つフラグやキューを見て、必要があるときだけ叩く。</li>
      <li><strong>起動時はローカルの途中状態を復旧する。</strong> Policyを表示できる時点で active_download_jobs を走査し、端末の実インストール状態と照合する。必要 version が既に入っていれば stale record を掃除し、<code>INSTALLING</code> のまま対象アプリが消えていてAPK bytesが残る場合は downloaded_artifact_index に戻す。そのうえで対応する WorkManager unique work を <code>KEEP</code> で再投入する。WorkManager側でまだ生きている work は増やさず、プロセス終了などで失われた work だけ再開する。</li>
      <li><strong>失敗はフェーズ単位で分類する。</strong> 「リカバリ可能 → DOWNLOAD は同じ active_download_jobs を retry 対象として維持し、INSTALL は同期完了や失敗確定の永続状態を作らず次の work list 再計算でリトライ」「リカバリ不能 → failed_artifacts_blacklist に追記」。新しいエラーが出てきたらまずこの2分類に当てはめる。</li>
      <li><strong>進行中/完了済みダウンロードは release.id + version_code で重複排除する。</strong> active_download_jobs がある間は UI の該当操作を無効化し、ローカル download state を表示する。非リトライ失敗・明示キャンセル・インストール成功・リカバリ不能なインストール失敗では active_download_jobs を消す。ユーザー確認待ち、PackageInstaller UI のユーザーキャンセル、AVAILABLE 更新の先取りでは downloaded_artifact_index を残し、後続INSTALLで保存済みAPKを使う。</li>
      <li><strong>サーバー報告はリカバリ不能な失敗だけ。</strong> リカバリ可能な失敗 (一時的) は端末側のリトライで吸収する。サーバー側で「同じエラーが何度も来ている」を観測したくなったら、それはリカバリ可能/不能の判定を見直す合図。</li>
      <li><strong>FCMは「再取得の合図」だけ。</strong> Policy本文をdata payloadに載せない。ユーザー向け通知も出さない。</li>
      <li><strong>fetched / applied / failed_artifacts_blacklist / pending_report_payload を別オブジェクトで持つ。</strong> 「取得済み」「恒久失敗」「未送信報告」「報告まで完了したか」を1つの値に潰さない。work item の途中進捗は永続化しない。</li>
      <li><strong>過去revisionは消さない。</strong> Policy変更は新規revision追加で表現する。</li>
      <li><strong>端末側で判断できる事はサーバーに持ち込まない。</strong> install_mode、現在のpackage一覧、権限の有無、フェーズ別エラーの分類は端末が知っている。サーバーはあるべき状態だけ持ち、リトライ・経路選択・通知制御は端末に寄せる。</li>
      <li><strong>installed_by_companion を立てたものだけ削除する。</strong> ユーザーが他経路で入れたアプリは絶対にUNINSTALLしない。</li>
      <li><strong>結果報告はログ。Policy本体を書き換えない。</strong> device_policy_sync_reports は監査・観測用。失敗が観測されたから Policy を変えるようなフィードバックを入れない。</li>
      <li><strong>同期失敗は監視対象にする。</strong> device_policy_sync_reports は監査ログであり、集計側で失敗率・未報告率・FCM送信失敗率をダッシュボード化する。初期アラートは「1時間のリカバリ不能失敗率5%超」「FCM恒久失敗急増」を目安にする。</li>
      <li><strong>AVAILABLEに自動インストールを足さない。</strong> 未インストールのAVAILABLEはユーザー導線が前提で、確定判定にも含めない (常に skip)。ただし既にインストール済みのAVAILABLEに更新がある場合は、オンプレサーバーが到達可能なうちに更新APKだけ先取りダウンロードしてよい。</li>
      <li><strong>admin による PUT は楽観的ロックを入れない。</strong> 同じ admin が冪等に PUT する前提。最後に書いた entries が current_revision になる。並列編集の整合は admin UI 側 (再 GET → 編集 → 再 PUT) で吸収する。</li>
    </ol>
    <p>判断に詰まったら <code>AGENTS.md</code> の "Data Modeling" セクション、および本ページの Data model 表を参照してください。AMAPI管理対象端末・非管理端末、および AMAPI custom app install の前提を満たすかどうかの差は「インストール経路の差 (<code>route</code>: <code>AMAPI_CUSTOM_APP</code> / <code>PACKAGE_INSTALLER</code>)」として <code>policy_sync_results</code> に記録するだけで、Policyのスキーマでは区別しません。AMAPI custom app install の前提条件は <a href="/android-app-prereq/#install-axis">Androidアプリ導入の前提 #インストール経路という独立した軸</a> を参照。</p>
  </section>
</BaseLayout>
