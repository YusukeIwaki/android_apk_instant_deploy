---
import DiagramFrame from "../../../components/DiagramFrame.astro";
import Mermaid from "../../../components/Mermaid.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";

const updatePolicyCurl = `curl -X PUT https://distribution.example.test/api/devices/drt_01HX9A2W.../policy \\
  -H "Authorization: Bearer $ADMIN_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    "entries": [
      { "package_name": "com.example.appa", "release": { "id": 301 }, "install_mode": "FORCE_INSTALLED" },
      { "package_name": "com.example.appb", "release": { "id": 302 }, "install_mode": "FORCE_INSTALLED" },
      { "package_name": "com.example.appc", "release": { "id": 303 }, "install_mode": "FORCE_INSTALLED" },
      { "package_name": "com.example.appd", "release": { "id": 304 }, "install_mode": "AVAILABLE" }
    ]
  }'`;

const updatePolicyResponse = `HTTP/1.1 200 OK
{
  "device_policy": {
    "identifier": "drt_01HX9A2W...",
    "current_revision": { "id": 901 },
    "updated_at": "2026-05-19T10:12:00+09:00",
    "entries": [
      { "package_name": "com.example.appa", "release": { "id": 301 }, "version_code": 1, "install_mode": "FORCE_INSTALLED" },
      { "package_name": "com.example.appb", "release": { "id": 302 }, "version_code": 1, "install_mode": "FORCE_INSTALLED" },
      { "package_name": "com.example.appc", "release": { "id": 303 }, "version_code": 1, "install_mode": "FORCE_INSTALLED" },
      { "package_name": "com.example.appd", "release": { "id": 304 }, "version_code": 1, "install_mode": "AVAILABLE" }
    ]
  },
  "push": {
    "type": "POLICY_UPDATED",
    "notification": null
  }
}`;

const fcmDataMessage = `{
  "message": {
    "token": "fcm:APA91b...",
    "data": {
      "type": "POLICY_UPDATED",
      "identifier": "drt_01HX9A2W...",
      "device_policy_updated_at": "2026-05-19T10:12:00+09:00"
    }
  }
}

# notification payload は含めない。
# FCM push はユーザー向け通知ではなく、Policy 再取得の契機だけを与える。`;

const fetchPolicyCurl = `curl -X GET https://distribution.example.test/api/devices/me/policy \\
  -H "Authorization: Bearer $DEVICE_AUTH_TOKEN"`;

const fetchPolicyResponse = `HTTP/1.1 200 OK
{
  "device_policy_revision": { "id": 901 },
  "updated_at": "2026-05-19T10:12:00+09:00",
  "server_time": "2026-05-19T10:12:04+09:00",
  "entries": [
    { "package_name": "com.example.appa", "release": { "id": 301 }, "version_code": 1, "install_mode": "FORCE_INSTALLED" },
    { "package_name": "com.example.appb", "release": { "id": 302 }, "version_code": 1, "install_mode": "FORCE_INSTALLED" },
    { "package_name": "com.example.appc", "release": { "id": 303 }, "version_code": 1, "install_mode": "FORCE_INSTALLED" },
    { "package_name": "com.example.appd", "release": { "id": 304 }, "version_code": 1, "install_mode": "AVAILABLE" }
  ]
}`;

const downloadUrlCurl = `curl -X GET https://distribution.example.test/api/releases/301/artifact_url \\
  -H "Authorization: Bearer $DEVICE_AUTH_TOKEN"

# FORCE_INSTALLED で未インストール、または要求version_codeと異なる場合だけ取得する。
# AVAILABLE のApp Dは、ユーザーがアプリ内UIから選んだときだけ取得する。
# 応答は短命の presigned URL を返し、端末は受け取った直後にダウンロードする。`;

const syncReportCurl = `curl -X POST https://distribution.example.test/api/devices/me/policy_sync_results \\
  -H "Authorization: Bearer $DEVICE_AUTH_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    "device_policy_revision": { "id": 901 },
    "fetched_policy_updated_at": "2026-05-19T10:12:04+09:00",
    "applied_policy_updated_at": "2026-05-19T10:13:20+09:00",
    "actions": [
      { "package_name": "com.example.appa", "action": "INSTALL", "route": "DEVICE_OWNER", "result": "INSTALLED" },
      { "package_name": "com.example.legacy", "action": "UNINSTALL", "route": "PACKAGE_MANAGER", "result": "UNINSTALLED" }
    ]
  }'`;

const policyFlow = `flowchart TD
  PolicyEdit["管理者 / CIがDevicePolicyを更新"] --> ServerPolicy["device_policy_revisions<br/>あるべき状態を保存"]
  ServerPolicy --> Push["FCM data message<br/>POLICY_UPDATED"]
  Push --> Fetch["端末がPolicyを再取得"]
  Manual["アプリUIの手動更新"] --> Fetch
  Launch["アプリ起動"] --> NeedSync{"fetched snapshotが<br/>applied snapshotより新しい?"}
  Fetch --> LocalFetched["端末ローカルストア<br/>fetched policy snapshotを保存"]
  LocalFetched --> NeedSync
  NeedSync -->|はい| Compare["インストール済みアプリとPolicyを比較"]
  NeedSync -->|いいえ| Idle["同期不要"]
  Compare --> Install["FORCE_INSTALLEDをインストール"]
  Compare --> Keep["AVAILABLEは手動導線だけ表示"]
  Compare --> Uninstall["Policyにない<br/>companion-installed appを削除"]
  Install --> Route{"DeviceOwnerまたは<br/>権限委譲あり?"}
  Route -->|はい| Silent["サイレントインストール"]
  Route -->|いいえ| Sticky["Sticky通知でユーザーに促す"]
  Silent --> Report["結果報告 + applied snapshot更新"]
  Sticky --> Report
  Uninstall --> Report`;

const dataModel = `flowchart LR
  subgraph Server["APIサーバー / DB"]
    DP["device_policies<br/>device_id / current_revision_id<br/>updated_at"]
    DPR["device_policy_revisions<br/>id / device_policy_id<br/>created_at / created_by"]
    DPE["device_policy_app_entries<br/>device_policy_revision_id / release_id<br/>package_name / version_code / install_mode"]
    Releases["releases<br/>app_id / version_code / artifact"]
  end

  subgraph DeviceLocal["端末ローカルストア"]
    Fetched["fetched_policy_snapshot<br/>最後に取得したPolicy本文<br/>updated_at"]
    Applied["applied_policy_snapshot<br/>実際にインストール状態が追いついたPolicy<br/>updated_at"]
    Pkgs["installed_package_index<br/>package_name / version_code<br/>installed_by_companion"]
  end

  DP --> DPR --> DPE
  DPE --> Releases
  DPE -. "GET policy" .-> Fetched
  Fetched -. "sync成功時のみ" .-> Applied
  Pkgs --- Applied`;

const sequence = `sequenceDiagram
  autonumber
  actor Admin as 管理者 / CI
  actor User as デバイス利用者
  participant Api as APIサーバー
  participant Push as FCM
  participant App as コンパニオンアプリ
  participant Local as 端末ローカルストア
  participant Owner as DeviceOwner / 権限委譲
  participant Os as Android PackageInstaller

  Admin->>Api: DevicePolicyを更新
  Api->>Api: device_policy_revisionsとentriesを保存
  Api->>Push: POLICY_UPDATED data messageを送信
  Push-->>App: data message、通知表示なし
  App->>Api: 最新Policyを取得
  App->>Local: fetched policy snapshotを保存
  User->>App: 手動でPolicy更新を実行
  App->>Api: 最新Policyを取得
  App->>Local: fetched policy snapshotを上書き
  App->>Local: fetched snapshot > applied snapshotなら同期開始
  App->>App: FORCE_INSTALLED / AVAILABLE / 削除対象を判定
  alt DeviceOwnerまたは権限委譲あり
    App->>Owner: サイレントインストール / アンインストール
    Owner-->>App: 結果
  else 権限なし
    App->>App: Sticky通知を維持
    User->>App: 通知からインストール操作
    App->>Os: PackageInstaller UIを起動
    Os-->>App: 結果
  end
  App->>Local: 同期完了時にapplied policy snapshotを更新
  App->>Api: policy sync resultを報告`;

const lifecycle = `stateDiagram-v2
  [*] --> Synced
  Synced --> PolicyFetched: FCM data message / 手動更新 / app起動時取得
  PolicyFetched --> SyncNeeded: fetched_policy.updated_at > applied_policy.updated_at
  PolicyFetched --> Synced: fetched snapshotとapplied snapshotが同じ
  SyncNeeded --> Planning: installed packagesとPolicyを比較
  Planning --> ApplyingSilent: DeviceOwnerまたは権限委譲あり
  Planning --> WaitingUserInstall: 権限なし + FORCE_INSTALLED不足
  ApplyingSilent --> Synced: install / uninstall完了
  WaitingUserInstall --> ApplyingUserInstall: ユーザーがSticky通知から操作
  ApplyingUserInstall --> Synced: PackageInstaller完了
  WaitingUserInstall --> SyncNeeded: app起動時に再通知 / 再同期
  Synced --> [*]`;
---

<BaseLayout
  title="アプリの配信"
  description="デバイスごとのDevicePolicyを更新し、端末がPolicyを再取得して、強制インストール・手動提供・削除を同期します。"
  currentPath="/use-cases/app-distribution/"
>
  <p class="lede">
    アプリ配信は、個別の配信ジョブを端末へ投げる処理ではなく、デバイスごとに1つあるDevicePolicyを更新し、端末がその「あるべき状態」に同期する処理です。
    FCM push はユーザー向けの通知ではなく、Policyが更新されたことをコンパニオンアプリに知らせ、Policy再取得の契機を与えるためだけに使います。
    端末は <code>fetched_policy_snapshot</code> (最後に取得したPolicy) と <code>applied_policy_snapshot</code> (実際にインストール状態が追いついたPolicy) を別オブジェクトとして持ち、両者を比較して同期の要否を判断します。
  </p>

  <section aria-labelledby="actors">
    <p class="section-kicker">Actors and responsibilities</p>
    <h2 id="actors">登場人物と責務</h2>
    <div class="table-wrap">
      <table class="usa-table">
        <thead>
          <tr>
            <th scope="col">登場人物</th>
            <th scope="col">きっかけ</th>
            <th scope="col">責務</th>
            <th scope="col">触るリソース</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <th scope="row">管理者 / CI</th>
            <td>デバイスへ配るアプリ構成を変えたい</td>
            <td>PUT /api/devices/:identifier/policy で DevicePolicy を更新する。release は事前に「アプリの登録」で用意しておく。</td>
            <td>device_policies, device_policy_revisions, device_policy_app_entries</td>
          </tr>
          <tr>
            <th scope="row">APIサーバー</th>
            <td>PUT policy / GET policy / POST policy_sync_results</td>
            <td>Policy更新を不変revisionとして保存し、FCM data messageを送信。GETでは最新revisionを返す。同期結果報告は監査ログとして書く (Policy本文は書き換えない)。</td>
            <td>device_policies, device_policy_revisions, device_policy_app_entries, device_policy_sync_reports, fcm_push_tokens (送信先解決)</td>
          </tr>
          <tr>
            <th scope="row">FCM</th>
            <td>APIサーバーからのsend</td>
            <td>data message を端末アプリへ届ける。data 内容は POLICY_UPDATED と identifier、updated_at のみ。</td>
            <td>FCM data payload (notification payload は使わない)</td>
          </tr>
          <tr>
            <th scope="row">コンパニオンアプリ</th>
            <td>FCM受信 / 手動更新 / app起動時</td>
            <td>Policyを再取得して fetched snapshot を保存。fetched と applied が一致するまで、インストール・更新・削除を試みる。完了時に applied snapshot を更新し、結果をサーバーへ報告する。</td>
            <td>fetched_policy_snapshot, applied_policy_snapshot, installed_package_index, DeviceOwner SDK / PackageInstaller</td>
          </tr>
          <tr>
            <th scope="row">端末利用者</th>
            <td>(自動経路では介在しない) / (フォールバック経路で) Sticky通知タップ</td>
            <td>自動インストール不可の端末で、通知からPackageInstaller UIへ進む。任意アプリ (AVAILABLE) はアプリUI内から自分で選んで入れる。</td>
            <td>PackageInstaller UI</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section aria-labelledby="data-model">
    <p class="section-kicker">Data model</p>
    <h2 id="data-model">DevicePolicy と端末ローカルストアの関係</h2>
    <Mermaid chart={dataModel} title="サーバー側のdevice_policy_*と端末側のpolicy snapshotの関係" />
    <dl class="key-value-list">
      <div>
        <dt>device_policies</dt>
        <dd>device 1つにつき1行。<code>current_revision_id</code> と <code>updated_at</code> を持ち、識別は devices.identifier で行う。Policy 本体の内容はここには持たず、revision を参照する。</dd>
      </div>
      <div>
        <dt>device_policy_revisions</dt>
        <dd>不変のrevision行。device_policy_id、created_at、created_by を持つ。Policyの変更はこのテーブルへの新規行追加で表現し、過去revisionは消さない。独自のrevision用identifierは作らず、ActiveRecord id を使う。</dd>
      </div>
      <div>
        <dt>device_policy_app_entries</dt>
        <dd>revisionに紐づくapp単位のエントリ。device_policy_revision_id、release_id、package_name、version_code、install_mode (FORCE_INSTALLED | AVAILABLE) を持つ。release_id は releases.id を参照する。</dd>
      </div>
      <div>
        <dt>fetched_policy_snapshot (端末ローカル)</dt>
        <dd>サーバーから最後に取得できたPolicy本文。FCM受信、手動更新、アプリ起動時取得で上書きされる。updated_at はこのsnapshotが置き換わった時刻。SQLiteの別テーブルでも Jetpack DataStore のobjectでもよい。</dd>
      </div>
      <div>
        <dt>applied_policy_snapshot (端末ローカル)</dt>
        <dd>端末上のインストール状態が実際に追いついたPolicy。同期成功時だけ fetched から複製される。<code>fetched.updated_at &gt; applied.updated_at</code> の間は同期対象。メタデータ更新ではこの値を動かさない。</dd>
      </div>
      <div>
        <dt>installed_package_index (端末ローカル)</dt>
        <dd>端末上の package_name、version_code、installed_by_companion を保持または再スキャン。「ユーザーが外部で入れたアプリ」と「このアプリが入れたアプリ」を区別し、UNINSTALL対象を絞り込む。</dd>
      </div>
    </dl>
  </section>

  <section aria-labelledby="distribution-flow">
    <p class="section-kicker">Flow with data</p>
    <h2 id="distribution-flow">処理フロー</h2>

    <article class="flow-step" aria-labelledby="step-1">
      <div class="flow-step__header">
        <span class="flow-step__number">1</span>
        <div>
          <h3 id="step-1">管理者がデバイスのDevicePolicyを更新する</h3>
          <p>1デバイスにつき1つのDevicePolicyを持ちます。例ではApp A/B/Cのversion_code 1を強制インストール (FORCE_INSTALLED)、App Dのversion_code 1をユーザー手動インストール可能 (AVAILABLE) として定義します。Policy更新は新しい revision の追加であり、過去 revision は不変です。</p>
        </div>
      </div>
      <div class="flow-step__grid">
        <div>
          <DiagramFrame src="/mocks/app-distribution/step-1-policy-editor.html" title="管理画面: デバイスPolicy編集" />
        </div>
        <div class="flow-step__details">
          <h4>API呼び出し</h4>
          <pre class="curl-block"><code>{updatePolicyCurl}</code></pre>
          <h4>応答</h4>
          <pre class="curl-block"><code>{updatePolicyResponse}</code></pre>
          <h4>作成・更新されるDBデータ</h4>
          <dl class="db-list">
            <div>
              <dt>device_policies</dt>
              <dd>device_id ごとに1行。current_revision_id と updated_at を更新する。deviceの特定は devices.identifier で行い、devices 本体にPolicy内容を混ぜない。</dd>
            </div>
            <div>
              <dt>device_policy_revisions</dt>
              <dd>新しい revision を不変行として作成する。id、device_policy_id、created_at、created_by を持つ。</dd>
            </div>
            <div>
              <dt>device_policy_app_entries</dt>
              <dd>新しい revision に紐づく entry を作成する。release_id は releases.id を参照する。install_mode は FORCE_INSTALLED または AVAILABLE。</dd>
            </div>
          </dl>
          <h4>作成しないもの</h4>
          <dl class="db-list">
            <div>
              <dt>rollout_jobs / device_install_tasks</dt>
              <dd>作成しない。端末はDevicePolicyを取得して自分で差分同期する。</dd>
            </div>
            <div>
              <dt>過去 revision の更新・削除</dt>
              <dd>過去 revision は不変。差し戻しは古い revision を current にし直すのではなく、同じ内容で新しい revision を作る。</dd>
            </div>
          </dl>
        </div>
      </div>
    </article>

    <article class="flow-step" aria-labelledby="step-2">
      <div class="flow-step__header">
        <span class="flow-step__number">2</span>
        <div>
          <h3 id="step-2">FCM pushまたは手動操作を契機にPolicyを再取得する</h3>
          <p>FCMは data message としてPolicy更新だけを届けます。notification payload は含めず、端末通知も表示しません。アプリUIからの手動更新、およびアプリ起動時にも同じPolicy取得APIを呼び、fetched snapshot を最新に保ちます。</p>
        </div>
      </div>
      <div class="flow-step__grid">
        <div>
          <DiagramFrame src="/mocks/app-distribution/step-2-policy-fetch.html" title="コンパニオンアプリ: Policy再取得" />
        </div>
        <div class="flow-step__details">
          <h4>FCM data message</h4>
          <pre class="curl-block"><code>{fcmDataMessage}</code></pre>
          <h4>API呼び出し</h4>
          <pre class="curl-block"><code>{fetchPolicyCurl}</code></pre>
          <h4>応答</h4>
          <pre class="curl-block"><code>{fetchPolicyResponse}</code></pre>
          <h4>端末ローカルデータの扱い</h4>
          <dl class="db-list">
            <div>
              <dt>fetched_policy_snapshot</dt>
              <dd>取得したPolicy本文で上書きする。サーバー側の device_policy_revisions は読み取りだけで変更しない。</dd>
            </div>
            <div>
              <dt>applied_policy_snapshot</dt>
              <dd>この時点では更新しない。fetched と applied を別オブジェクトとして持つことで、取得済みだが未適用のPolicyを表現する。</dd>
            </div>
            <div>
              <dt>端末通知</dt>
              <dd>FCM data message 受信そのものでは表示しない。表示するのは、強制インストールが必要で権限がない場合だけ後続ステップで出すSticky通知のみ。</dd>
            </div>
          </dl>
        </div>
      </div>
    </article>

    <article class="flow-step" aria-labelledby="step-3">
      <div class="flow-step__header">
        <span class="flow-step__number">3</span>
        <div>
          <h3 id="step-3">取得済みPolicyと端末状態を比較して同期計画を作る</h3>
          <p>fetched_policy.updated_at が applied_policy.updated_at より新しい限り、アプリ起動時にも同期を試みます。強制対象 (FORCE_INSTALLED) の不足分はインストールし、Policy から消えた companion-installed app は削除します。AVAILABLE はユーザー導線にだけ並べ、自動で入れません。</p>
        </div>
      </div>
      <div class="flow-step__grid">
        <div>
          <DiagramFrame src="/mocks/app-distribution/step-3-sync-plan.html" title="コンパニオンアプリ: Policy差分同期計画" />
        </div>
        <div class="flow-step__details">
          <h4>必要なときだけ artifact URL を取得する</h4>
          <pre class="curl-block"><code>{downloadUrlCurl}</code></pre>
          <h4>同期対象の決め方</h4>
          <dl class="db-list">
            <div>
              <dt>installed_package_index</dt>
              <dd>端末上の package_name、version_code、installed_by_companion を保持または PackageManager から再スキャン。ユーザーが外部で入れたアプリとこのアプリが入れたアプリを区別する。</dd>
            </div>
            <div>
              <dt>INSTALL対象</dt>
              <dd>FORCE_INSTALLED かつ「未インストール」または「要求version_codeと異なる」package。</dd>
            </div>
            <div>
              <dt>UNINSTALL対象</dt>
              <dd>Policyに定義がなく、かつ <code>installed_by_companion = true</code> の package。PolicyにAVAILABLEとして残るApp Dは削除しない。ユーザーが他経路で入れたものも対象外。</dd>
            </div>
            <div>
              <dt>SHOW対象 (AVAILABLE)</dt>
              <dd>アプリ内UIの一覧に表示するだけで自動インストールしない。ユーザーが選んだときに artifact URL を取得してインストールする。</dd>
            </div>
          </dl>
        </div>
      </div>
    </article>

    <article class="flow-step" aria-labelledby="step-4">
      <div class="flow-step__header">
        <span class="flow-step__number">4</span>
        <div>
          <h3 id="step-4">権限に応じて強制インストールを実行し、同期完了を記録する</h3>
          <p>DeviceOwner権限またはインストール権限の委譲があればサイレントインストールします。権限がなければ、強制対象が満たされるまでStickyな通知でユーザーにインストールを促し続けます。同期が成功した範囲だけ applied snapshot を更新します。</p>
        </div>
      </div>
      <div class="flow-step__grid">
        <div>
          <DiagramFrame src="/mocks/app-distribution/step-4-install-route.html" title="コンパニオンアプリ: 強制インストール経路" />
        </div>
        <div class="flow-step__details">
          <h4>同期結果報告</h4>
          <pre class="curl-block"><code>{syncReportCurl}</code></pre>
          <h4>記録するDBと端末ローカルデータ</h4>
          <dl class="db-list">
            <div>
              <dt>applied_policy_snapshot (端末)</dt>
              <dd>必要なインストールと削除が完了したときだけ、fetched snapshot の device_policy_revision.id、Policy本文、updated_at を applied へ反映する。部分成功では更新しない。</dd>
            </div>
            <div>
              <dt>Sticky install notification (端末)</dt>
              <dd>権限なしで FORCE_INSTALLED が未達の場合だけ表示する。ユーザーがキャンセルしてもPolicyが未同期なら、アプリ起動時や再同期時に再表示する。</dd>
            </div>
            <div>
              <dt>device_policy_sync_reports (サーバー)</dt>
              <dd>device_policy_revision_id、実行した action、route (DEVICE_OWNER / PACKAGE_MANAGER)、result、reported_at を記録する。Policy本体は結果報告では書き換えない。</dd>
            </div>
            <div>
              <dt>fcm_push_tokens / releases / artifacts</dt>
              <dd>同期結果報告では更新しない。push宛先とrelease metadataは別のライフサイクルで管理する。</dd>
            </div>
          </dl>
        </div>
      </div>
    </article>
  </section>

  <section aria-labelledby="ownership">
    <p class="section-kicker">Data ownership</p>
    <h2 id="ownership">Policy同期で誰がどのデータを持つか</h2>
    <Mermaid chart={policyFlow} title="DevicePolicy更新から端末同期完了まで" />
    <div class="table-wrap">
      <table class="usa-table">
        <thead>
          <tr>
            <th scope="col">データ</th>
            <th scope="col">保持場所</th>
            <th scope="col">用途</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <th scope="row">DevicePolicy</th>
            <td>サーバーの device_policies / device_policy_revisions / device_policy_app_entries</td>
            <td>1デバイスのあるべきアプリ状態を表す。devicesのidentityには混ぜない。</td>
          </tr>
          <tr>
            <th scope="row">install_mode</th>
            <td>device_policy_app_entries</td>
            <td>FORCE_INSTALLEDは同期時に満たす対象、AVAILABLEはユーザーがアプリUIから手動取得できる対象。</td>
          </tr>
          <tr>
            <th scope="row">fetched policy snapshot</th>
            <td>端末ローカルストア</td>
            <td>最後にサーバーから取得できたPolicy本文。FCM受信、手動更新、アプリ起動時取得で更新される。</td>
          </tr>
          <tr>
            <th scope="row">applied policy snapshot</th>
            <td>端末ローカルストア (fetched とは別オブジェクト)</td>
            <td>端末上のインストール状態が実際に追いついたPolicy。<code>fetched.updated_at &gt; applied.updated_at</code> の間は同期対象。</td>
          </tr>
          <tr>
            <th scope="row">installed_by_companion</th>
            <td>端末ローカルの installed_package_index</td>
            <td>Policyから消えたアプリを削除してよいか判断する。このアプリが入れたものだけ削除対象にする。</td>
          </tr>
          <tr>
            <th scope="row">device_policy_sync_reports</th>
            <td>サーバー</td>
            <td>各revisionに対する端末側の同期結果ログ。Policy本体は書き換えない。</td>
          </tr>
        </tbody>
      </table>
    </div>
