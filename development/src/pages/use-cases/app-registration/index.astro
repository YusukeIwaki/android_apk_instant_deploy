---
import DiagramFrame from "../../../components/DiagramFrame.astro";
import Mermaid from "../../../components/Mermaid.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";

const uploadCurl = `curl -X POST https://distribution.example.test/admin/artifacts \\
  -H "Authorization: Bearer $ADMIN_TOKEN" \\
  -F "file=@qa-camera-2.4.0-42.apk;type=application/vnd.android.package-archive"`;

const uploadCli = `ANDROID_APK_INSTANT_DEPLOY_SERVER=https://distribution.example.test \\
ANDROID_APK_INSTANT_DEPLOY_ACCESS_TOKEN=$ADMIN_TOKEN \\
android_apk_instant_deploy upload qa-camera-2.4.0-42.apk`;

const uploadResponse = `HTTP/1.1 201 Created
{
  "artifact": {
    "id": 101,
    "filename": "qa-camera-2.4.0-42.apk",
    "sha256": "58f7d4...",
    "size_bytes": 50541312,
    "signing_cert_sha256": "9a5c0e..."
  }
}`;

const newVersionCurl = `curl -X POST https://distribution.example.test/admin/artifacts \\
  -H "Authorization: Bearer $ADMIN_TOKEN" \\
  -F "file=@qa-camera-2.4.1-43.apk;type=application/vnd.android.package-archive"

# 既存パッケージの新しいバージョンを追加する場合も同じエンドポイントへ送る。
# - APK の checksum が新規 (これまで未登録) なら、新しい release 行を追加する
# - 同じ package_name / version_code でも checksum が異なれば新しい release 行を追加する
# - 古い release はそのまま残る (削除は管理者が明示的に DELETE する)
# - 完全に同じ APK bytes は拒否される (400 ARTIFACT_ALREADY_EXISTS)`;

const newVersionCli = `ANDROID_APK_INSTANT_DEPLOY_SERVER=https://distribution.example.test \\
ANDROID_APK_INSTANT_DEPLOY_ACCESS_TOKEN=$ADMIN_TOKEN \\
android_apk_instant_deploy upload qa-camera-2.4.1-43.apk`;

const newVersionResponse = `HTTP/1.1 201 Created
{
  "artifact": {
    "id": 102,
    "filename": "qa-camera-2.4.1-43.apk",
    "sha256": "a91c0b...",
    "size_bytes": 50621984,
    "signing_cert_sha256": "9a5c0e..."
  }
}

# 応答形は新規パッケージの初回アップロード時と同じ。
# 既存パッケージへの新バージョン追加でも、artifact メタデータのみを返す。
# 「どの release が増えたか」は GET /admin/apps/{package_name}/releases から確認する。`;

const artifactAlreadyExistsResponse = `HTTP/1.1 400 Bad Request
{
  "error": {
    "code": "ARTIFACT_ALREADY_EXISTS",
    "message": "The exact same APK artifact has already been uploaded. Re-uploading the same package_name and version_code is allowed only when the APK checksum differs."
  }
}

# release は append-only。
# 同じ package_name / version_code でも checksum が異なる APK は別 release として追加する。
# 完全に同じ APK bytes は二重登録しない。`;

const invalidApkResponse = `HTTP/1.1 400 Bad Request
{
  "error": {
    "code": "INVALID_APK",
    "message": "file must be a parseable APK."
  }
}

# APKとして解析できない場合は apps / releases / artifacts を変更しない。
# このときS3 objectも作成しない (検証 -> 保存 の順で実装する)。`;

const signingCertMismatchResponse = `HTTP/1.1 400 Bad Request
{
  "error": {
    "code": "SIGNING_CERT_MISMATCH",
    "message": "Signing certificate differs from the previously registered release for this package."
  }
}

# 同じ package_name で過去に登録済みの release と署名が異なる場合は拒否する。
# 端末側のPackageInstallerが署名差し替えを許可しないため、配信前に検出する。`;

const listAppsCurl = `curl -X GET https://distribution.example.test/admin/apps \\
  -H "Authorization: Bearer $ADMIN_TOKEN"`;

const listAppsCli = `ANDROID_APK_INSTANT_DEPLOY_SERVER=https://distribution.example.test \\
ANDROID_APK_INSTANT_DEPLOY_ACCESS_TOKEN=$ADMIN_TOKEN \\
android_apk_instant_deploy apps`;

const listAppsResponse = `HTTP/1.1 200 OK
{
  "apps": [
    {
      "display_name": "QA Camera",
      "package_name": "com.example.qacamera"
    },
    {
      "display_name": "Scanner",
      "package_name": "com.example.scanner"
    },
    {
      "display_name": "Kiosk",
      "package_name": "com.example.kiosk"
    }
  ]
}

# POST /admin/artifacts でアップロードが成功すると、新規 package はこの一覧に現れる。
# release の追加確認や削除に使う id は GET /admin/apps/{package_name}/releases で確認する。`;

const listReleasesCurl = `curl -X GET https://distribution.example.test/admin/apps/com.example.qacamera/releases \\
  -H "Authorization: Bearer $ADMIN_TOKEN"`;

const listReleasesCli = `ANDROID_APK_INSTANT_DEPLOY_SERVER=https://distribution.example.test \\
ANDROID_APK_INSTANT_DEPLOY_ACCESS_TOKEN=$ADMIN_TOKEN \\
android_apk_instant_deploy releases --app com.example.qacamera`;

const listReleasesResponse = `HTTP/1.1 200 OK
{
  "app": {
    "display_name": "QA Camera",
    "package_name": "com.example.qacamera"
  },
  "releases": [
    {
      "id": 301,
      "version_code": 42,
      "version_name": "2.4.0-qa",
      "artifact": {
        "id": 101,
        "filename": "qa-camera-2.4.0-42.apk",
        "sha256": "58f7d4...",
        "size_bytes": 50541312,
        "signing_cert_sha256": "9a5c0e..."
      }
    }
  ]
}`;

const deleteReleaseCurl = `curl -X DELETE https://distribution.example.test/admin/apps/com.example.qacamera/releases/301 \\
  -H "Authorization: Bearer $ADMIN_TOKEN"

# Response: 204 No Content`;

const deleteReleaseCli = `ANDROID_APK_INSTANT_DEPLOY_SERVER=https://distribution.example.test \\
ANDROID_APK_INSTANT_DEPLOY_ACCESS_TOKEN=$ADMIN_TOKEN \\
android_apk_instant_deploy delete_release 301 --app com.example.qacamera --yes`;

const relationshipDiagram = `flowchart LR
  subgraph App["apps: アプリidentity"]
    AppNode["id: 12 (AR primary key)<br/>package_name: com.example.qacamera<br/>created_at"]
    ProfileNode["app_profiles<br/>app_id: 12<br/>display_name: QA Camera"]
    IconNode["app_icons<br/>app_id: 12<br/>image_data (Shrine/S3)"]
  end

  subgraph Releases["releases: 配信で選ぶバージョン単位"]
    Release1["id: 301 (AR primary key)<br/>app_id: 12 / artifact_id: 101<br/>version_code: 42<br/>version_name: 2.4.0-qa"]
    Release2["id: 302 (AR primary key)<br/>app_id: 12 / artifact_id: 103<br/>version_code: 43<br/>version_name: 2.4.1"]
  end

  subgraph Artifacts["artifacts: APKファイルとS3参照"]
    Artifact1["id: 101 (AR primary key)<br/>s3_key: artifacts/101/app.apk<br/>sha256 / size_bytes<br/>signing_cert_sha256"]
    Artifact2["id: 103 (AR primary key)<br/>s3_key: artifacts/103/app.apk<br/>sha256 / size_bytes<br/>signing_cert_sha256"]
  end

  AppNode -->|"1 app has many releases"| Release1
  AppNode -->|"1 app has many releases"| Release2
  AppNode -->|"表示名は別概念"| ProfileNode
  AppNode -->|"アイコン画像は別model"| IconNode
  Release1 -->|"uses this APK"| Artifact1
  Release2 -->|"uses this APK"| Artifact2`;

const ownershipFlow = `flowchart LR
  subgraph Operator["管理者 / CI"]
    ApkFile["APK file"]
  end

  subgraph Api["APIサーバー"]
    InputFile["input[:file]"]
    Inspector["APK metadata extraction"]
    ArtifactService["artifact registration"]
  end

  subgraph S3["S3 artifact bucket"]
    S3Object["artifacts/{artifact.id}/file.apk"]
  end

  subgraph DB["DB / ActiveRecord"]
    Apps["apps<br/>id / package_name"]
    Profiles["app_profiles<br/>app_id / display_name"]
    Icons["app_icons<br/>app_id / image_data (Shrine)"]
    Artifacts["artifacts<br/>id / s3_key / sha256 / size_bytes / signing_cert_sha256"]
    Releases["releases<br/>id / app_id / artifact_id / version_code / version_name"]
  end

  ApkFile -->|POST multipart/form-data| InputFile
  InputFile --> Inspector
  InputFile -->|そのまま保存| S3Object
  Inspector --> ArtifactService
  S3Object --> ArtifactService
  ArtifactService --> Artifacts
  ArtifactService --> Apps
  ArtifactService --> Profiles
  ArtifactService --> Icons
  ArtifactService --> Releases
  Releases --> Artifacts
  Apps --> Releases
  Releases -. "Release destroyから推移" .-> Artifacts
  Artifacts -. "S3 cleanup" .-> S3Object`;

const artifactFlow = `flowchart TD
  Start["管理者 / CIがAPKを選択"] --> Post["POST /admin/artifacts<br/>multipart field: file"]
  Post --> Receive["APIサーバーがinput[:file]を受け取る"]
  Receive --> Parse["APKを解析<br/>package_name / version_code / version_name / sha256 / cert<br/>application label / icon"]
  Parse --> Valid{"APKとして受け入れ可能か"}
  Valid -->|いいえ| Reject["400 INVALID_APK で拒否<br/>apps / releases / artifacts / S3は変更しない"]
  Valid -->|はい| Dup{"同じ sha256 の artifact が<br/>既に存在?"}
  Dup -->|ある| RejectDup["400 ARTIFACT_ALREADY_EXISTS で拒否<br/>artifacts / S3 にも書かない"]
  Dup -->|ない| CertCheck{"既存 release と署名一致?"}
  CertCheck -->|不一致| RejectCert["400 SIGNING_CERT_MISMATCH で拒否<br/>S3にも書かない"]
  CertCheck -->|一致 or 新規 package| Upload["input[:file]をS3へアップロード"]
  Upload --> Artifact["artifacts作成<br/>S3 keyとAPK由来metadataを保存"]
  Artifact --> App["appsをpackage_nameで作成または参照<br/>(行が無ければ新しいidで新規作成)"]
  App --> Profile["app_profiles を更新<br/>APK label を表示名として保存"]
  App --> Icon["app_icons を更新<br/>抽出iconをShrineでS3保存"]
  Profile --> CreateRelease["releases を新規作成<br/>artifact_idを設定 (append-only)"]
  Icon --> CreateRelease
  CreateRelease --> Done["登録完了"]
  Done --> ReleaseDelete["後日、管理者が release を明示的に削除"]
  ReleaseDelete --> ArtifactDestroy["release削除から artifact 削除へ推移"]
  ArtifactDestroy --> Cleanup["artifact destroy callback で S3 objectを削除"]
  ReleaseDelete --> AppCheck{"その app の release が<br/>1つも残らない?"}
  AppCheck -->|はい| HardDelete["apps を hard delete<br/>device_policy_app_entries も FK CASCADE で削除"]
  AppCheck -->|いいえ| Keep["apps はそのまま"]`;

const sequence = `sequenceDiagram
  autonumber
  actor Operator as 管理者 / CI
  participant Api as APIサーバー
  participant Inspector as APK inspector
  participant S3 as S3 artifact bucket
  participant AR as ActiveRecord / DB

  Operator->>Api: POST /admin/artifacts(file)
    Api->>Inspector: input[:file]からAPK metadata / label / iconを抽出
  alt APKとして受け入れ可能 + 同じ artifact sha256 が無い + 署名一致
    Api->>S3: input[:file]をS3 objectとして保存
    Api->>AR: artifactsを作成
    Api->>AR: appsをpackage_nameで作成または参照
    Api->>AR: app_profiles / app_iconsを作成または更新
    Api->>AR: releasesを新規作成 (append-only)
    Api-->>Operator: artifact メタデータを返す
  else 不正なAPK / 既存 artifact sha256 / 署名不一致
    Api-->>Operator: 400 INVALID_APK / ARTIFACT_ALREADY_EXISTS / SIGNING_CERT_MISMATCH を返す
  end

  Operator->>Api: DELETE /admin/apps/:package_name/releases/:release_id
  Api->>AR: Release.destroy
  AR->>AR: 関連artifactをdestroy
  AR->>S3: artifact destroy callback で S3 objectを削除
  AR->>AR: その app の release が無くなれば apps を hard delete<br/>(device_policy_app_entries も FK CASCADE)
  Api-->>Operator: 204 No Content`;

const lifecycle = `stateDiagram-v2
  [*] --> FileSubmitted: POST /admin/artifacts(file)
  FileSubmitted --> Inspecting: input[:file]を解析
  Inspecting --> Rejected: APKではない / 解析不可 / 同一 artifact sha256 既存 / 署名不一致
  Inspecting --> StoredInS3: 受け入れ可能
  StoredInS3 --> ArtifactRecorded: artifacts作成
  ArtifactRecorded --> AppResolved: apps を作成 or 参照<br/>(行が無ければ新しい app.id で新規作成)
  AppResolved --> DisplayMetadata: app_profiles / app_icons を更新
  DisplayMetadata --> ReleaseLinked: releases を新規作成 (append-only)
  ReleaseLinked --> Registered: 登録結果を返す
  Registered --> Active: 配信可能
  Active --> ReleaseDeleting: DELETE /admin/apps/:package_name/releases/:release_id
  ReleaseDeleting --> ArtifactDestroying: Release 削除から推移
  ArtifactDestroying --> S3Deleted: S3 object 削除
  S3Deleted --> AppHardDeleted: その app の release が0件<br/>apps を hard delete<br/>device_policy_app_entries も FK CASCADE で削除
  S3Deleted --> Active: 他にも release が残っている
  Rejected --> [*]
  AppHardDeleted --> [*]: 同 package_name で再アップロードしても<br/>別の apps.id として新規作成される (復活はしない)`;
---

<BaseLayout
  title="アプリの登録"
  description="APKファイルを1回のアップロードで受け取り、S3上のartifact、apps、releasesを最小限の責務で確定します。"
  currentPath="/use-cases/app-registration/"
>
  <p class="lede">
    アプリ登録は、管理者またはCIがAPKファイルを1つアップロードする操作で完結します。
    APIサーバーは受け取った <code>input[:file]</code> を解析・検証し、APKとして妥当ならS3へ保存して、APKから読み取った package_name、version_code、version_name、署名、hash、サイズ、application label、icon をもとに、artifacts、apps、app_profiles、app_icons、releases を必要な分だけ作成または更新します。
    ユーザー操作として扱うのは <strong>Artifact作成 (POST /admin/artifacts)</strong> と <strong>Release削除 (DELETE /admin/apps/:package_name/releases/:release_id)</strong> の2つだけで、artifact 単体の作成・削除APIは提供しません。
    build source や changelog はこの登録データでは管理しません。
  </p>

  <section aria-labelledby="actors">
    <p class="section-kicker">Actors and responsibilities</p>
    <h2 id="actors">登場人物と責務</h2>
    <div class="table-wrap">
      <table class="usa-table">
        <thead>
          <tr>
            <th scope="col">登場人物</th>
            <th scope="col">きっかけ</th>
            <th scope="col">責務</th>
            <th scope="col">触るリソース</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <th scope="row">管理者 / CI</th>
            <td>新しいAPK ができた (新規 package or 新バージョン) / 配信対象から外したい</td>
            <td>POST /admin/artifacts でAPKをアップロードする。配信終了時は DELETE /admin/apps/:package_name/releases/:release_id を呼ぶ。</td>
            <td>artifacts, releases (経由で apps)</td>
          </tr>
          <tr>
            <th scope="row">APIサーバー</th>
            <td>POST /admin/artifacts / DELETE /admin/apps/:package_name/releases/:release_id</td>
            <td>APK解析 → 重複 checksum チェック → 署名検証 → S3保存 → artifact / (必要なら apps) / releases を1トランザクションで確定 (releases は常に append-only)。Release削除時は artifact を destroy して S3 object を削除し、その app の release が0件になったら apps を hard delete (関連 device_policy_app_entries も FK CASCADE で削除)。</td>
            <td>apps, artifacts, releases, S3 bucket</td>
          </tr>
          <tr>
            <th scope="row">S3 bucket</th>
            <td>APIサーバーからの put_object / delete_object</td>
            <td>APK bytes の保存先。key は <code>{`artifacts/{artifact.id}/{filename}`}</code>。本番は AWS S3、ローカル開発は S3互換エミュレータの <a href="https://github.com/floci-io/floci">floci</a> を使う (MinIO ではない)。サーバー側のクライアントは AWS SDK そのままで、エンドポイントだけ環境変数で差し替える。</td>
            <td>artifacts に紐づく単一の object</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section aria-labelledby="data-model">
    <p class="section-kicker">Data model</p>
    <h2 id="data-model">Artifact、apps、releasesの関係</h2>
    <Mermaid chart={relationshipDiagram} title="apps、releases、artifactsの関係と保持する情報" />
    <dl class="key-value-list">
      <div>
        <dt>artifacts</dt>
        <dd>アップロードされたAPKそのものを表す。S3 key、元ファイル名、content_type、sha256、size_bytes、signing_cert_sha256 など、APK bytes と保存先から決まる事実だけを持つ。ユーザー向けの直接削除APIは置かず、release削除から推移して削除される。</dd>
      </div>
      <div>
        <dt>apps</dt>
        <dd>package_name で識別される配布対象アプリのidentity。解析した package_name に対応する行がなければ作成し、あれば既存行を参照する。表示名、アイコン、changelog、build sourceは持たない。</dd>
      </div>
      <div>
        <dt>app_profiles</dt>
        <dd>APKから抽出した application label を、利用者向けの表示名として app_id と分けて保存する。package_name と lifecycle が異なる表示メタデータなので apps には混ぜない。</dd>
      </div>
      <div>
        <dt>app_icons</dt>
        <dd>APKから抽出した launcher icon を画像として保存する別model。Shrine の <code>image_data</code> でS3へアップロードし、アプリ一覧・任意アプリ詳細のアイコン表示に使う。</dd>
      </div>
      <div>
        <dt>releases</dt>
        <dd>app_id、artifact_id、version_code、version_name を持つバージョン単位の配信対象。同じ app_id + version_code でも artifact sha256 が異なれば別 release として作成する。ユーザーが削除する単位でもあり、削除時には関連artifactの削除へ推移する。</dd>
      </div>
    </dl>
  </section>

  <section aria-labelledby="registration-flow">
    <p class="section-kicker">Flow with data</p>
    <h2 id="registration-flow">処理フロー</h2>

    <article class="flow-step" aria-labelledby="step-1">
      <div class="flow-step__header">
        <span class="flow-step__number">1</span>
        <div>
          <h3 id="step-1">Artifact作成APIにAPKファイルを送る</h3>
          <p>エントリーポイントは画面操作ではなく、APKファイルを送るAPI呼び出しです。CIから直接呼んでも、管理画面から呼んでも同じAPIを使います。</p>
        </div>
      </div>
      <div class="flow-step__grid">
        <div>
          <DiagramFrame src="/mocks/app-registration/step-1-upload-url.html" title="管理画面: APKファイル選択" />
        </div>
        <div class="flow-step__details">
          <h4>REST APIの場合 (curl)</h4>
          <pre class="curl-block"><code>{uploadCurl}</code></pre>
          <h4>CLIツールの場合</h4>
          <pre class="curl-block"><code>{uploadCli}</code></pre>
          <h4>応答</h4>
          <pre class="curl-block"><code>{uploadResponse}</code></pre>
          <h4>入力の制約</h4>
          <dl class="db-list">
            <div>
              <dt>file</dt>
              <dd>受け取る入力はAPKファイルだけ。multipart field 名は <code>file</code> で、APIサーバー内では <code>input[:file]</code> として扱う。</dd>
            </div>
            <div>
              <dt>upload方式</dt>
              <dd>事前のpresigned URL発行、分割upload、一時cache storageは扱わない。単純な1リクエストのファイル受領を優先する。</dd>
            </div>
          </dl>
          <h4>応答の責務</h4>
          <p>応答は作成された artifact のメタデータ (<code>id</code>、<code>filename</code>、<code>sha256</code>、<code>size_bytes</code>、<code>signing_cert_sha256</code>) のみ。S3 の storage 種別や key などバックエンド都合の情報は含めない。サーバー内部では artifact と同じトランザクションで app と release も作成・更新するが、その結果は応答では返さず、管理者は次ステップの GET /admin/apps と GET /admin/apps/:package_name/releases で確認する。</p>
        </div>
      </div>
    </article>

    <article class="flow-step" aria-labelledby="step-2">
      <div class="flow-step__header">
        <span class="flow-step__number">2</span>
        <div>
          <h3 id="step-2">APIサーバーが <code>input[:file]</code> を検証・保存して artifact を作る</h3>
          <p>サーバーは受け取ったファイルをAPKとして解析し、APKとして妥当で、かつ既存 release との署名互換性も満たす場合に限りS3へアップロードします。同時に application label と launcher icon を抽出し、表示名は <code>app_profiles</code>、アイコンは Shrine 管理の <code>app_icons</code> として保存します。「検証 → 保存」の順序を守ることで、不正リクエストでS3に孤児オブジェクトを残さないようにします。</p>
        </div>
      </div>
      <div class="flow-step__grid">
        <div>
          <DiagramFrame src="/mocks/app-registration/step-2-upload-artifact.html" title="管理画面: 処理中表示" />
        </div>
        <div class="flow-step__details">
          <h4>作成されるデータ</h4>
          <dl class="db-list">
            <div>
              <dt>S3 object</dt>
              <dd>APK bytes を <code>{`artifacts/{artifact.id}/{filename}`}</code> の key で保存する。key は artifacts 行から参照できる形にする。</dd>
            </div>
            <div>
              <dt>artifacts</dt>
              <dd>S3 key と、APKから抽出した sha256、size_bytes、signing_cert_sha256 を保存する。artifact 独自の外部識別子は増やさず、行参照には ActiveRecord id を使う。</dd>
            </div>
            <div>
              <dt>app_profiles / app_icons</dt>
              <dd>APKから抽出した application label を <code>app_profiles.display_name</code> に保存し、launcher icon は <code>app_icons.image_data</code> として Shrine でS3に保存する。アイコン抽出や画像保存に失敗した場合は artifact 登録全体を失敗させるか、既定アイコンにフォールバックするかを実装前に選ぶ。</dd>
            </div>
          </dl>
        </div>
      </div>
    </article>

    <article class="flow-step" aria-labelledby="step-3">
      <div class="flow-step__header">
        <span class="flow-step__number">3</span>
        <div>
          <h3 id="step-3">GET /admin/apps と GET /admin/apps/:package_name/releases で登録結果を確認する</h3>
          <p>POST /admin/artifacts の応答は artifact メタデータだけなので、管理者は GET /admin/apps で「アップロードしたアプリが一覧に増えているか」を確認し、GET /admin/apps/:package_name/releases でリリース ID とバージョンを確認します。新規 package なら apps 一覧に1行追加され、既存 package への新バージョンなら該当 app の releases に新しい行が <strong>追加</strong> されます (古いリリースはそのまま残ります)。</p>
        </div>
      </div>
      <div class="flow-step__grid">
        <div>
          <DiagramFrame src="/mocks/app-registration/step-3-release-created.html" title="管理画面: アプリ一覧 (アップロード後)" />
        </div>
        <div class="flow-step__details">
          <h4>REST APIの場合 (curl): アプリ一覧</h4>
          <pre class="curl-block"><code>{listAppsCurl}</code></pre>
          <h4>CLIツールの場合: アプリ一覧</h4>
          <pre class="curl-block"><code>{listAppsCli}</code></pre>
          <h4>応答</h4>
          <pre class="curl-block"><code>{listAppsResponse}</code></pre>
          <h4>REST APIの場合 (curl): リリース一覧</h4>
          <pre class="curl-block"><code>{listReleasesCurl}</code></pre>
          <h4>CLIツールの場合: リリース一覧</h4>
          <pre class="curl-block"><code>{listReleasesCli}</code></pre>
          <h4>応答</h4>
          <pre class="curl-block"><code>{listReleasesResponse}</code></pre>
          <h4>既存パッケージへ新バージョンを追加する場合</h4>
          <pre class="curl-block"><code>{newVersionCurl}</code></pre>
          <h4>CLIツールの場合</h4>
          <pre class="curl-block"><code>{newVersionCli}</code></pre>
          <h4>応答 (新バージョン)</h4>
          <pre class="curl-block"><code>{newVersionResponse}</code></pre>
          <h4>append-only の挙動</h4>
          <dl class="db-list">
            <div>
              <dt>releases</dt>
              <dd>checksum が未登録なら常に新規行として追加。古い release.id はそのまま残り続け、artifact と S3 object も削除されない。DevicePolicy は app を参照しているため、新しい release が増えただけで Policy entries は変わらない。端末は次の Policy fetch で「最新release」として新しい version_code と artifact sha256 を受け取る。</dd>
            </div>
            <div>
              <dt>同じ APK bytes を再送した場合</dt>
              <dd>400 ARTIFACT_ALREADY_EXISTS で拒否する。artifacts も S3 も触らない。同じ package_name / version_code でも checksum が異なれば新しい release として追加する。</dd>
            </div>
          </dl>
        </div>
      </div>
    </article>

    <article class="flow-step" aria-labelledby="step-4">
      <div class="flow-step__header">
        <span class="flow-step__number">4</span>
        <div>
          <h3 id="step-4">Release削除時にartifactとS3 objectも削除する</h3>
          <p>不要になったAPKを配信対象から外す操作は Release 削除です。Release を削除すると関連 artifact の削除へ推移し、その artifact 削除時にS3 object も削除します。DevicePolicy は app を参照しているため、release を消しても Policy entries は変わりません。当該 app に他の release が残っていれば、端末は次の Policy fetch で「新しい最新リリース」を install として受け取ります。</p>
        </div>
      </div>
      <div class="flow-step__grid">
        <div>
          <DiagramFrame src="/mocks/app-registration/step-4-registration-result.html" title="管理画面: リリース削除完了" />
        </div>
        <div class="flow-step__details">
          <h4>REST APIの場合 (curl)</h4>
          <pre class="curl-block"><code>{deleteReleaseCurl}</code></pre>
          <h4>CLIツールの場合</h4>
          <pre class="curl-block"><code>{deleteReleaseCli}</code></pre>
          <h4>DB / S3 の扱い</h4>
          <dl class="db-list">
            <div>
              <dt>releases</dt>
              <dd>管理者またはCIが削除する単位。削除後は release catalog から消える。</dd>
            </div>
            <div>
              <dt>artifacts</dt>
              <dd>release から外れたタイミングで destroy。S3 object も同時に削除する。直接削除APIは提供しない。</dd>
            </div>
            <div>
              <dt>apps</dt>
              <dd>その app の release が全て削除された時点で <strong>hard delete</strong> する。soft-delete 用の <code>deleted_at</code> カラムは持たない。同じ <code>package_name</code> で再アップロードがあった場合は <em>新しい <code>apps.id</code> として新規作成</em> し、旧 id は復活させない。</dd>
            </div>
            <div>
              <dt>device_policy_app_entries</dt>
              <dd>apps の hard delete に伴い、FK CASCADE で関連 entry も同時に削除される。「削除されたアプリ entry」 が宙に浮く状態は発生しない。Policy を再構成したい場合は admin が明示的に新しい app.id で PUT する。</dd>
            </div>
          </dl>
        </div>
      </div>
    </article>
  </section>

  <section aria-labelledby="ownership">
    <p class="section-kicker">Data ownership</p>
    <h2 id="ownership">誰がどのidentifierと事実を持つか</h2>
    <Mermaid chart={ownershipFlow} title="APK file、input[:file]、S3、apps、artifacts、releasesの関係" />
    <div class="table-wrap">
      <table class="usa-table">
        <thead>
          <tr>
            <th scope="col">identifier / fact</th>
            <th scope="col">生成者</th>
            <th scope="col">保持場所</th>
            <th scope="col">用途</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <th scope="row"><code>input[:file]</code></th>
            <td>管理者またはCIのmultipart upload</td>
            <td>APIリクエスト内。DBには保存しない。</td>
            <td>S3保存とAPK metadata抽出の入力。事前アップロード済みfile idや任意URLではない。</td>
          </tr>
          <tr>
            <th scope="row">S3 key</th>
            <td>APIサーバー</td>
            <td>artifacts</td>
            <td>APK bytes の保存先。release削除から推移したartifact destroy時に、このkeyのobjectを削除する。</td>
          </tr>
          <tr>
            <th scope="row">package_name</th>
            <td>APK解析</td>
            <td>apps</td>
            <td>配布対象アプリを識別する安定した事実。DB行の参照には apps.id を使う。</td>
          </tr>
          <tr>
            <th scope="row">application label / launcher icon</th>
            <td>APK解析</td>
            <td>app_profiles / app_icons (Shrine/S3)</td>
            <td>Androidアプリのホーム (アプリ一覧) とアプリ詳細で表示するアプリ名とアイコン。identity ではないため apps には保存しない。</td>
          </tr>
          <tr>
            <th scope="row">version_code / version_name</th>
            <td>APK解析</td>
            <td>releases</td>
            <td>特定アプリのバージョンを表す release ごとの事実。app_id + version_code で作成または更新対象を決める。</td>
          </tr>
          <tr>
            <th scope="row">sha256 / size_bytes / signing_cert_sha256</th>
            <td>APIサーバーのAPK解析</td>
            <td>artifacts</td>
            <td>アップロードされたAPK bytesの確認、重複検出、署名互換性判断に使う。</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

