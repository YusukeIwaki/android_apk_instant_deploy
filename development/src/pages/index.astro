---
import BaseLayout from "../layouts/BaseLayout.astro";

const pages = [
  {
    label: "デバイスの登録",
    href: "/use-cases/device-registration/",
    summary: "管理者が発行した登録リンクから、コンパニオンアプリがFCM tokenと表示名を添えて devices を作るまで。Android Management API のenrollmentとは別物。",
    audience: "サーバー / Androidアプリ"
  },
  {
    label: "アプリの登録",
    href: "/use-cases/app-registration/",
    summary: "管理者/CIが1回のAPKアップロードで apps / artifacts / releases を確定するまで。Release削除でS3 objectまで連動して消えるところまで。",
    audience: "サーバー / CI"
  },
  {
    label: "アプリの配信",
    href: "/use-cases/app-distribution/",
    summary: "デバイスごとのDevicePolicyを更新し、FCMを契機に端末が再取得、必須インストール・任意提供・削除を同期するまで。",
    audience: "サーバー / Androidアプリ"
  },
  {
    label: "Androidアプリ導入の前提",
    href: "/android-app-prereq/",
    summary: "コンパニオンアプリ自体を端末へ入れる前提を、AMAPI管理端末のforce installと手動インストールの2経路で整理します。",
    audience: "Androidアプリ / 端末管理"
  },
  {
    label: "Androidアプリ削除時の挙動",
    href: "/android-app-removal/",
    summary: "アプリ削除・データ初期化・再インストールで端末側の実体が消えたとき、FCM恒久失敗とheartbeat途絶からサーバー側データをcleanupする設計。",
    audience: "サーバー / Androidアプリ"
  },
  {
    label: "Android画面一覧",
    href: "/openapi/android-screens/",
    summary: "Androidコンパニオンアプリで必要になる画面を、Material WebベースのモックとAPI・データ制約で横並びに確認するためのページ。",
    audience: "Androidアプリ / サーバー"
  },
  {
    label: "同期/リトライ機構",
    href: "/sync-retry/",
    summary: "Policy fetch・ダウンロード・インストール・結果報告を端末側で進める同期エンジンの状態モデル、トリガ、判定基準、リトライ計画を1枚で読むためのページ。",
    audience: "Androidアプリ / サーバー"
  },
  {
    label: "OpenAPI",
    href: "/openapi/",
    summary: "上記3ユースケースで使う具体的なエンドポイント・スキーマの一覧。実装時のリファレンス。",
    audience: "サーバー / Androidアプリ"
  }
];
---

<BaseLayout
  title="ユースケース別設計"
  description="APK配信システムの設計ドキュメント。3つのユースケースとOpenAPIで構成されています。"
  currentPath="/"
>
  <section aria-labelledby="reading-guide">
    <h2 id="reading-guide">読み方ガイド</h2>
    <p>
      各ユースケースページは <strong>登場人物と責務 / データモデル / 処理フロー / Data ownership / Sequence / Lifecycle / 主要エラー / 判断指針</strong> の順に並んでいます。
      まず冒頭の lede と「登場人物と責務」表で全体像を掴み、「処理フロー」で各ステップを順に確認し、ページ末尾の「主要エラー」と「判断指針」で例外と原則を抑える、という順で読むと最短です。
      ページ内のモック画像 (Chromeフレーム / スマートフォンフレーム) は <em>その画面で操作者または利用者が見るもの</em> だけを表現しています。
      API・DB・端末ローカルストアの責務は、モック横の「API呼び出し」「作成されるDBデータ」セクションを正としてください。
    </p>
  </section>

  <section aria-labelledby="page-list">
    <h2 id="page-list">ページ一覧</h2>
    <ul class="usa-list page-index-list">
      {pages.map((page) => (
        <li>
          <a href={page.href}><strong>{page.label}</strong></a>
          <div class="page-index-summary">{page.summary}</div>
          <div class="page-index-audience">対象: {page.audience}</div>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
